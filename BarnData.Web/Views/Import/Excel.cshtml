@{
    ViewData["Title"]    = "Import Excel";
    ViewData["Subtitle"] = "Upload an .xlsx file to preview and import animal records";
}

<div style="max-width:560px">
    <div class="table-card" style="padding:28px 32px">
        <h2 style="font-size:15px;font-weight:600;margin-bottom:6px">Upload Excel file</h2>
        <p style="font-size:12.5px;color:var(--text3);margin-bottom:22px">
            The file must be <strong>.xlsx</strong> format. Columns are matched by header name —
            see the expected column names below.
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error" style="margin-bottom:16px">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" enctype="multipart/form-data" asp-action="Excel">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:18px">
                <label style="display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:6px">
                    Excel file (.xlsx)
                </label>
                <input type="file" name="file" accept=".xlsx"
                       style="font-size:13px;width:100%;padding:8px 10px;border:1px solid var(--gray3);
                              border-radius:var(--radius);background:#fff;" />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%">
                Upload &amp; Preview →
            </button>
        </form>
    </div>

    <!-- Expected columns reference -->
    <div class="table-card" style="margin-top:16px;padding:20px 24px">
        <div style="font-size:12px;font-weight:600;margin-bottom:10px;color:var(--text2)">
            Expected column headers
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 24px;font-size:12px;color:var(--text3)">
            <div>Control No <span style="color:var(--gray4)">(optional)</span></div>
            <div>Animal Type</div>
            <div>Tag Number One</div>
            <div>Tag Number Two</div>
            <div>Purchase Date</div>
            <div>Purchase Type</div>
            <div>Vendor</div>
            <div>Live Weight</div>
            <div>Live Rate</div>
            <div>Kill Date</div>
            <div>Hot Weight</div>
            <div>Grade</div>
            <div>H S</div>
            <div>Comments</div>
            <div>Animal Control Number</div>
            <div>Tag 3</div>
            <div>Office use 2</div>
            <div>State</div>
            <div>Buyer</div>
            <div>Animal Type 2</div>
            <div>Vet Name</div>
        </div>
        <div style="margin-top:12px;font-size:11.5px;color:var(--text3)">
            Columns are matched case-insensitively. Missing columns are imported as blank.
            Rows with a blank Tag Number One are skipped.
        </div>
    </div>
</div>
