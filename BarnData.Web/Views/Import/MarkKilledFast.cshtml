// Save Hot Weight data for ALL pages in one call (server-driven).
// Calls SaveAllHwData endpoint which reads HW preview from session, writes
// HotWeight/Grade/HS/ACN to every matching bill, and marks them Loaded.
// Bills stay in KillStatus=Pending — finalize via "Mark all complete (all pages)".
async function saveAllHwData() {
    const btns = document.querySelectorAll('#saveHwBtn,#saveHwBtn2');
    const originalText = btns[0]?.textContent || 'Save HW data';

    if (!confirm('Save Hot Weight data (HotWeight, Grade, HS, ACN) for all loaded rows across every page? Bills stay Pending — you can review and then finalize via "Mark all complete (all pages)".')) {
        return;
    }

    btns.forEach(b => { b.disabled = true; b.textContent = 'Saving all pages…'; });

    try {
        const res = await fetch('/Import/SaveAllHwData', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': AF_TOKEN }
        });
        const data = await res.json();
        showMsg(data.message, !data.success);
        if (data.success) {
            // Reload after a moment so the visible page reflects the saved state
            // (rows that were pre-fill yellow now show as plain saved bills).
            setTimeout(() => window.location.reload(), 1500);
        } else {
            btns.forEach(b => { b.disabled = false; b.textContent = originalText; });
        }
    } catch (e) {
        showMsg('Save failed: ' + e.message, true);
        btns.forEach(b => { b.disabled = false; b.textContent = originalText; });
    }
}

