            "input[name^='animalCtrlNo_']",
            "input[name^='liveWeight_']",
            "input[name^='killDate_']",
            "input[name^='hotWeight_']",
            "select[name^='grade_']",
            "input[name^='healthScore_']",
            "input[type='checkbox'][name^='condemned_']"
        ].join(","),
        wrap: true,
        onRowFocus: function (rowEl) {
            if (!rowEl) return;
        }
    });
});
