// Save all HW-imported rows regardless of change detection
async function saveAllHwData() {
    const rows = [...document.querySelectorAll('tr.animal-row[data-hw-imported="1"]')].map(readRow)
        .filter(r => r.hotWeight > 0 || r.grade || r.healthScore > 0);
    if (!rows.length) { showMsg('No HW import data found to save.', true); return; }

    const btns = document.querySelectorAll('#saveHwBtn,#saveHwBtn2');
    btns.forEach(b => { b.disabled = true; b.textContent = 'Saving…'; });

    try {
        const res  = await fetch('/Import/SaveEditsApi', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': AF_TOKEN },
            body:    JSON.stringify({ rows })
        });
        const data = await res.json();
        showMsg(data.message, !data.success);
        if (data.success) {
            // Clear hw-imported flag on all rows
            document.querySelectorAll('tr.animal-row[data-hw-imported="1"]').forEach(tr => {
                tr.dataset.hwImported = '0';
                tr.classList.remove('hw-imported-row', 'edited-row');
            });
            btns.forEach(b => b.style.display = 'none');
        }
    } catch(e) {
        showMsg('Save failed: ' + e.message, true);
    } finally {
        btns.forEach(b => { b.disabled = false; b.textContent = 'Save HW data'; });
    }
}

document.addEventListener("DOMContentLoaded", function () {
    // Show "Save HW data" button if any HW-imported rows exist
    var hwRows = document.querySelectorAll('tr.animal-row[data-hw-imported="1"]');
    if (hwRows.length > 0) {
        document.querySelectorAll('#saveHwBtn,#saveHwBtn2').forEach(b => {
            b.style.display = 'inline-flex';
            b.textContent = 'Save HW data (' + hwRows.length + ' rows)';
        });
    }
    refreshCompleteCount();
    applyRowFilters();
    if (!window.BarnNav) return;
    var table = document.getElementById("mainTable");
    if (!table) return;
    BarnNav.registerGrid({
        container: table,
        rowSelector: "tbody tr.animal-row",
        cellSelector: [
            "input[name^='animalCtrlNo_']",
            "input[name^='liveWeight_']",
            "input[name^='killDate_']",
            "input[name^='hotWeight_']",
            "select[name^='grade_']",
            "input[name^='healthScore_']",
            "input[type='checkbox'][name^='condemned_']"
        ].join(","),
        wrap: true,
        onRowFocus: function (rowEl) {
            if (!rowEl) return;
            var chk = rowEl.querySelector(".animal-chk");
            if (chk && !chk.checked) {
                chk.checked = true;
                if (typeof highlightRow === "function") highlightRow(chk);
                if (typeof updateCount === "function") updateCount();
                refreshCompleteCount();
            }
        }
    });
});
