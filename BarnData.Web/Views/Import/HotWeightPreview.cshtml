@*@using DocumentFormat.OpenXml.Office2010.PowerPoint*@
@model BarnData.Web.Models.HotWeightImportViewModel?
@{
    ViewData["Title"]    = "Import Hot Weight Report";
    ViewData["Subtitle"] = "Upload, preview, and manage Hot Scale data";

    bool hasData         = Model != null && Model.TotalInExcel > 0;
    var okRows           = Model?.AutoRows.Where(r => r.Status == "OK").ToList() ?? new();
    var loadedRows       = Model?.AutoRows.Where(r => r.Status == "Loaded").ToList() ?? new();
    var readyDisplayRows = okRows;
    var flagRows         = Model?.FlaggedRows.ToList() ?? new();
    var dupRows          = Model?.DupRows.ToList() ?? new();
    var validGrades      = new[] { "CT","B1","B2","CN","LB","UB","BB","BR","FB","NP","NPNP","SH" };
}

@*
    Banner system (manual-refresh design):
    - Success/Error flash messages render globally in _Layout.cshtml
      (above the page content) so we don't render them again here.
    - InfoMessage is local to this page since Layout doesn't currently
      render it.
    - Persistent status banner showing how stale the staged data is, with the Refresh button.
*@
@if (TempData["InfoMessage"] != null)
{
    <div class="alert" style="margin-bottom:14px;background:#F3F4F6;border:1px solid #D1D5DB;border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:10px;font-size:12.5px">
        <span style="font-size:16px">○</span>
        <div style="flex:1"><strong>@TempData["InfoMessage"]</strong></div>
    </div>
}

@*
    Persistent "last refreshed" status. Always visible so operators see at a
    glance how stale the staged data is. Click Refresh from Hot Scale to pull
    today's latest. Pulls take 30–60 seconds — the only time the page is slow.
*@
@{
    DateTime? lastRefreshUtc = ViewBag.LastRefreshedUtc as DateTime?;
    double? ageMinutes = ViewBag.LastRefreshedAgeMinutes as double?;
    string staleness;
    string staleColor;
    string staleBg;
    if (!lastRefreshUtc.HasValue)
    {
        staleness  = "Never refreshed";
        staleColor = "#92400E"; staleBg = "#FFFBEB";
    }
    else if (ageMinutes < 5)
    {
        staleness  = $"Just refreshed ({lastRefreshUtc.Value.ToLocalTime():HH:mm})";
        staleColor = "#065F46"; staleBg = "#ECFDF5";
    }
    else if (ageMinutes < 60)
    {
        staleness  = $"Last refreshed {(int)ageMinutes!.Value} min ago ({lastRefreshUtc.Value.ToLocalTime():HH:mm})";
        staleColor = "#075985"; staleBg = "#EFF6FF";
    }
    else if (ageMinutes < 24 * 60)
    {
        staleness  = $"Last refreshed {(int)(ageMinutes!.Value / 60)} hr ago ({lastRefreshUtc.Value.ToLocalTime():HH:mm})";
        staleColor = "#92400E"; staleBg = "#FFFBEB";
    }
    else
    {
        staleness  = $"Last refreshed {lastRefreshUtc.Value.ToLocalTime():yyyy-MM-dd HH:mm} (stale)";
        staleColor = "#991B1B"; staleBg = "#FEF2F2";
    }
}
<div class="alert" style="margin-bottom:14px;background:@staleBg;border:1px solid @staleColor;border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:10px;font-size:12.5px;color:@staleColor">
    <span style="font-size:16px">↻</span>
    <div style="flex:1">
        <strong>@staleness</strong>
        <span style="color:var(--text3)"> Click Refresh to pull the latest from Hot Scale (takes 30–60 sec).</span>
    </div>
    <form method="post" asp-action="HotWeightRefreshFromHotScale" style="margin:0">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary btn-sm">Refresh from Hot Scale</button>
    </form>
    <form method="post" asp-action="HotWeightClearSession" style="margin:0 0 0 6px"
          onsubmit="return confirm('Clear all Hot Weight session data? This wipes the current staging and the Mark Killed pre-fill.');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-secondary btn-sm" title="Wipe all staged Hot Weight data and start fresh">Clear session</button>
    </form>
</div>

@* Page header  *@
<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div>
        <h1 class="page-title" style="margin:0">Import Hot Weight Report</h1>
        @if (hasData)
        {
            <p style="font-size:12.5px;color:var(--text3);margin-top:3px">
                File: <strong>@Model!.FileName</strong> — @Model!.TotalInExcel unique animals (after merging duplicate scale-machine rows), @Model!.Matched matched to bills.
                <span style="color:var(--amber);font-weight:500"> Session active — nothing saved to DB yet unless you used "Save to DB".</span>
            </p>
        }
        else
        {
            <p style="font-size:12.5px;color:var(--text3);margin-top:3px">Upload a Hot Scale Parsed Data Excel file to populate the tabs below.</p>
        }
    </div>
    @if (hasData)
    {
        <a asp-action="MarkKilled" class="btn btn-secondary btn-sm">Go to Mark as Killed</a>
    }
</div>

@if (Model?.Errors?.Any() == true)
{
    <div class="alert alert-error" style="margin-bottom:14px">
        @foreach (var e in Model.Errors)
        {
            <div>@e</div>
        }
    </div>
}



@*  Single-row merged card-tabs (stats + tabs combined)  *@
<div class="hw-tabbar hw-cardtabs">
    <button class="hw-ctab active" id="tab0" onclick="switchTab(0)" type="button" title="All rows in uploaded Excel">
        <div class="hw-ctab-n" id="sc0-n">@(hasData ? Model!.TotalInExcel.ToString() : "—")</div>
        <div class="hw-ctab-l">Rows in Excel</div>
    </button>
    <button class="hw-ctab" id="tab1" onclick="switchTab(1)" type="button" title="Ready to load + already killed today">
        <div class="hw-ctab-n hw-n-green" id="sc1-n">@(hasData ? readyDisplayRows.Count.ToString() : "—")</div>
        <div class="hw-ctab-l">Ready &amp; killed today</div>
    </button>
    <button class="hw-ctab" id="tab2" onclick="switchTab(2)" type="button" title="Rows needing review">
        <div class="hw-ctab-n hw-n-red" id="sc2-n">@(hasData ? flagRows.Count.ToString() : "—")</div>
        <div class="hw-ctab-l">Flagged for review</div>
    </button>
    <button class="hw-ctab" id="tab3" onclick="switchTab(3)" type="button" title="Duplicate rows">
        <div class="hw-ctab-n hw-n-purple" id="sc3-n">@(hasData ? dupRows.Count.ToString() : "—")</div>
        <div class="hw-ctab-l">Duplicates</div>
    </button>
</div>
@* legacy hidden counters kept so any JS that still references cnt2 / cnt3 keeps working *@
<span id="cnt2" style="display:none">@(hasData ? flagRows.Count.ToString() : "—")</span>
<span id="cnt3" style="display:none">@(hasData ? dupRows.Count.ToString() : "—")</span>

@* 
   TAB 0 — All rows / Upload zone
    *@
<div id="panel0" class="hw-panel">
    @* Upload card always visible at top *@
    <div style="background:var(--gray1);border-radius:8px;padding:14px 18px;margin-bottom:@(hasData ? "14px" : "0")">
        <div style="font-size:12px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">
            @(hasData ? "Upload a new file (replaces current session)" : "Upload Hot Scale file to get started")
        </div>
        <form method="post" enctype="multipart/form-data" asp-action="HotWeightImport" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
            @Html.AntiForgeryToken()
            <div style="flex:1;min-width:220px">
                <input type="file" name="file" accept=".xlsx" class="form-control" required style="font-size:12.5px" />
                <div style="font-size:11.5px;color:var(--text3);margin-top:4px">
                    Expected columns: <code>Number</code>, <code>Side 1 Hot</code>, <code>Side 2 Hot</code>, <code>Grade</code>, <code>HealthScore</code>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Upload &amp; Parse</button>
            @if (hasData)
            {
                <form method="post" asp-action="HotWeightClearSession" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm" style="background:#fef2f2;border-color:#fca5a5;color:#b91c1c"
                            onclick="return confirm('Clear the session? All parsed data will be lost and you will need to re-upload.')">
                        Clear session
                    </button>
                </form>
            }
        </form>
    </div>

    @* Summary table shown when data exists *@
    @if (hasData)
    {
        @* One-line summary so the math is obvious *@
        <p style="font-size:12.5px;color:var(--text3);margin:8px 0 6px">
            Of <strong>@Model!.TotalInExcel</strong> rows pulled from Hot Scale:
            <strong style="color:#15803d">@okRows.Count</strong> ready,
            <strong style="color:#6d28d9">@loadedRows.Count</strong> already killed,
            <strong style="color:#b91c1c">@flagRows.Count</strong> need fixing,
            <strong style="color:#7c3aed">@dupRows.Count</strong> duplicates.
        </p>
        <table style="width:100%;max-width:680px;font-size:13px;border-collapse:collapse">
            <thead><tr style="background:var(--gray1)">
                <th style="padding:7px 10px;text-align:left;font-weight:500;color:var(--text3);border-bottom:1px solid var(--gray3)">Category</th>
                <th style="padding:7px 10px;text-align:right;font-weight:500;color:var(--text3);border-bottom:1px solid var(--gray3)">Count</th>
                <th style="padding:7px 10px;text-align:left;font-weight:500;color:var(--text3);border-bottom:1px solid var(--gray3)">What it means</th>
            </tr></thead>
            <tbody>
                <tr style="border-bottom:0.5px solid var(--gray3)">
                    <td style="padding:8px 10px;color:#15803d;font-weight:500">Ready to load</td>
                    <td style="padding:8px 10px;text-align:right;font-weight:700">@okRows.Count</td>
                    <td style="padding:8px 10px;font-size:12px;color:var(--text3)">Pre-fills HotWeight, Grade, HS in Mark as Killed when loaded</td>
                </tr>
                <tr style="border-bottom:0.5px solid var(--gray3)">
                    <td style="padding:8px 10px;color:#6d28d9;font-weight:500">Already killed today</td>
                    <td style="padding:8px 10px;text-align:right;font-weight:700">@loadedRows.Count</td>
                    <td style="padding:8px 10px;font-size:12px;color:var(--text3)">Loaded into Mark Killed and saved earlier today — no further action needed</td>
                </tr>
                <tr style="border-bottom:0.5px solid var(--gray3)">
                    <td style="padding:8px 10px;color:#b91c1c;font-weight:500">Need review (flagged)</td>
                    <td style="padding:8px 10px;text-align:right;font-weight:700">@flagRows.Count</td>
                    <td style="padding:8px 10px;font-size:12px;color:var(--text3)">Missing or invalid data — fix on Flagged tab to send to Mark as Killed</td>
                </tr>
                <tr>
                    <td style="padding:8px 10px;color:#7c3aed;font-weight:500">Duplicates (already in DB)</td>
                    <td style="padding:8px 10px;text-align:right;font-weight:700">@dupRows.Count</td>
                    <td style="padding:8px 10px;font-size:12px;color:var(--text3)">Hot Scale row matches a bill that already has the same data — skipped</td>
                </tr>
            </tbody>
        </table>
        @if (okRows.Any())
        {
            <div style="margin-top:14px">
                <form method="post" asp-action="HotWeightLoadToMarkKilled" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="selectedControlNos" value="">
                    <input type="hidden" name="fixedFlaggedJson" value="">
                    <button type="submit" class="btn btn-primary">Load @okRows.Count ready records into Mark as Killed →</button>
                </form>
            </div>
        }
    }
</div>

@* 
   TAB 1 — Ready to load
   *@
<div id="panel1" class="hw-panel" style="display:none">
    @if (!hasData)
    {
        <div class="empty-state"><div class="empty-title">No data yet</div><div class="empty-sub">Upload a Hot Scale Excel file using the All rows tab.</div></div>
    }
    else if (!readyDisplayRows.Any())
    {
        <div class="empty-state"><div class="empty-title">No ready records</div><div class="empty-sub">All matched records are either flagged or not yet in the system.</div></div>
    }
    else
    {
        <div class="hw-toolbar">
            <span style="font-size:12.5px;color:var(--text2)"><strong id="p1-sel">@okRows.Count</strong> of @okRows.Count selected</span>
            <button type="button" onclick="selAll('p1',true)" class="btn btn-secondary btn-sm">Select all</button>
            <button type="button" onclick="selAll('p1',false)" class="btn btn-secondary btn-sm">Deselect all</button>
            <div style="margin-left:auto">
                <button type="button" onclick="loadSelected('p1')" class="btn btn-primary">Load selected into Mark as Killed →</button>
            </div>
        </div>
        <div class="xl-scroll-box"><div class="xl-scroll-inner auto-fill-scroll">
        <table class="data-table" data-colfilter-table style="min-width:1900px;font-size:12px">
    <thead><tr>
        <th style="width:32px;text-align:center"><input type="checkbox" id="p1-all" onchange="selAll('p1',this.checked)"></th>
        <th data-colfilter="text">ACN</th>
        <th data-colfilter="text">LOT</th>
        <th data-colfilter="text">Type</th>
        <th data-colfilter="text">BackTag</th>
        <th data-colfilter="text">Tag1</th>
        <th data-colfilter="text">Tag2</th>
        <th data-colfilter="text">Program</th>
        <th data-colfilter="text">Origin</th>
        <th data-colfilter="number" class="text-right">LiveWeight</th>
        <th data-colfilter="number" class="text-right">Side1 (lbs)</th>
        <th data-colfilter="number" class="text-right">Side2 (lbs)</th>
        <th data-colfilter="number" class="text-right" style="background:#162236;color:#9ae6b4">HotTotal</th>
        <th data-colfilter="text" style="background:#162236;color:#9ae6b4">Grade</th>
        <th data-colfilter="text" style="background:#162236;color:#9ae6b4">Grade2</th>
        <th data-colfilter="number" style="background:#162236;color:#9ae6b4">HealthScore</th>
        <th data-colfilter="text">Status</th>
    </tr></thead>
    <tbody>
    @foreach (var r in readyDisplayRows)
    {
        var isLoaded = r.Status == "Loaded";
        <tr data-ctrlno="@r.ControlNo" style="@(isLoaded ? "opacity:0.6" : "")">
            <td style="text-align:center">
                <input type="checkbox" class="p1-chk" data-ctrlno="@r.ControlNo"
                       onchange="updSel('p1')"
                                @(isLoaded ? "disabled" : "")>
            </td>
            <td class="mono">
                @{
                    // Prefer the bill's existing ACN; if empty (e.g. matched by
                    // tag, not ACN), show the proposed ACN from Hot Scale.
                    var displayAcn = !string.IsNullOrWhiteSpace(r.AnimalControlNumber)
                        ? r.AnimalControlNumber
                        : r.NewAnimalControlNumber;
                }
                @if (string.IsNullOrWhiteSpace(displayAcn))
                {
                    <span style="color:#9ca3af">—</span>
                }
                else if (string.IsNullOrWhiteSpace(r.AnimalControlNumber)
                         && !string.IsNullOrWhiteSpace(r.NewAnimalControlNumber))
                {
                    <span title="Proposed from Hot Scale" style="color:#0d9488">@displayAcn</span>
                }
                else
                {
                    @displayAcn
                }
            </td>
            <td>@(r.FileLot ?? "—")</td>
            <td>@(r.FileType ?? "—")</td>
            <td>@(r.FileBackTag ?? "—")</td>
            <td>@(r.FileTag1 ?? "—")</td>
            <td>@(r.FileTag2 ?? "—")</td>
            <td>@(r.FileProgram ?? "—")</td>
            <td>@(r.FileOrigin ?? "—")</td>
            <td class="text-right mono">@(r.FileLiveWeight.HasValue ? r.FileLiveWeight.Value.ToString("N1") : "—")</td>
            <td class="text-right mono">@r.Side1?.ToString("N1")</td>
            <td class="text-right mono">@r.Side2?.ToString("N1")</td>
            <td class="text-right mono" style="color:@(isLoaded ? "#6d28d9" : "#15803d");font-weight:600">@r.NewHotWeight?.ToString("N1")</td>
            <td><span class="badge" style="background:@(isLoaded ? "#f5f3ff" : "#dcfce7");color:@(isLoaded ? "#6d28d9" : "#15803d")">@r.NewGrade</span></td>
            <td>@(r.NewGrade2 ?? "—")</td>
            <td>@r.NewHealthScore</td>
            <td>
                @if (r.IsCondemned)
                {
                    <span class="badge" style="background:#fef2f2;color:#991b1b;font-size:11px;font-weight:600" title="Condemned animal — no carcass weight">🚫 Condemned</span>
                }
                else
                {
                    <span class="badge" style="background:@(isLoaded ? "#f5f3ff" : "#dcfce7");color:@(isLoaded ? "#6d28d9" : "#15803d");font-size:11px">@(isLoaded ? "Loaded ✓" : "Ready")</span>
                }
            </td>
        </tr>
    }
    </tbody>
    </table>
        </div></div>
    }
</div>

@* 
   TAB 2 - Flagged for review (editable)
    *@
<div id="panel2" class="hw-panel" style="display:none">
    @if (!hasData)
    {
        <div class="empty-state"><div class="empty-title">No data yet</div><div class="empty-sub">Upload a file using the All rows tab.</div></div>
    }
    else if (!flagRows.Any())
    {
        <div class="empty-state"><div class="empty-title">No flagged records</div><div class="empty-sub">All matched records passed validation.</div></div>
    }
    else
    {
        @* Inline save confirmation banner — hidden until save completes *@
        <div id="save-confirm" style="display:none;background:#f0fdf4;border:1px solid #86efac;border-radius:6px;padding:10px 16px;margin-bottom:10px;font-size:12.5px;color:#15803d">
            <strong>Saved to database.</strong> <span id="save-confirm-msg"></span>
            <span style="color:#64748b"> These values are now visible in Animal List and included in Export Excel.</span>
        </div>

        <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:6px;padding:10px 14px;margin-bottom:10px;font-size:12.5px;color:#b91c1c">
            <strong>@flagRows.Count records need attention.</strong>
            Fill in Grade and HS where missing. When Side1, Side2, Grade and HS are all valid the row turns
            <span style="background:#eff6ff;padding:1px 6px;border-radius:3px;color:#1e40af;font-size:11.5px;font-weight:600">blue</span>
            and Load enables. Trim variance rows can be accepted as-is — just click Load.
            "ACN not found" rows are read-only — Delete only.
        </div>
        <div class="hw-toolbar">
            <span style="font-size:12.5px;color:var(--text2)">
                <strong id="p2-fixed-count">0</strong> fixed &nbsp;·&nbsp; <strong id="p2-sel">0</strong> selected
            </span>
            <input type="text" id="p2-filter" placeholder="Filter ACN or reason…"
                   oninput="filterFlagged()"
                   style="padding:4px 9px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;width:190px">
            <button type="button" onclick="selAllFixed()" class="btn btn-secondary btn-sm">Select all fixed</button>
            <button type="button" onclick="selAll('p2',false)" class="btn btn-secondary btn-sm">Deselect all</button>
            <button type="button" onclick="deleteSelectedFlagged()" class="btn btn-sm" style="background:#fef2f2;border-color:#fca5a5;color:#b91c1c">Delete selected</button>
            <div style="margin-left:auto;display:flex;gap:6px">
                <button type="button" onclick="loadSelectedFlagged()" id="p2-load-btn" class="btn btn-secondary btn-sm" disabled>Load into Mark as Killed</button>
                <button type="button" onclick="saveFixedToDB()" id="p2-save-btn" class="btn btn-primary btn-sm" disabled>Save to DB →</button>
            </div>
        </div>
       <div class="xl-scroll-box"><div class="xl-scroll-inner auto-fill-scroll">
        <table class="data-table" id="p2-table" style="min-width:2300px;font-size:12px">
            <thead><tr>
    <th style="width:32px;position:sticky;left:0;z-index:8;background:#1e2f47">
        <input type="checkbox" id="p2-all" onchange="selAllVisible(this.checked)">
        </th>
        <th style="width:120px;position:sticky;left:32px;z-index:8;background:#1e2f47">ACN</th>
        <th style="width:70px;position:sticky;left:152px;z-index:8;background:#1e2f47">LOT</th>
        <th style="width:120px;position:sticky;left:222px;z-index:8;background:#1e2f47">BackTag</th>
        <th style="width:90px;position:sticky;left:342px;z-index:8;background:#1e2f47;border-right:2px solid #162236">Tag1</th>

        <th>Type</th>
        <th>Sex</th>
        <th>Tag2</th>
        <th>Program</th>
        <th>Origin</th>
        <th class="text-right">LiveWeight</th>
        <th class="text-right" style="background:#162236;color:#9ae6b4">Side1 ✎</th>
        <th class="text-right" style="background:#162236;color:#9ae6b4">Side2 ✎</th>
        <th class="text-right" style="background:#162236;color:#9ae6b4">Hot Total</th>
        <th style="background:#162236;color:#9ae6b4">Grade ✎</th>
        <th style="background:#162236;color:#9ae6b4">Grade2 ✎</th>
        <th style="background:#162236;color:#9ae6b4">HS ✎</th>
        <th style="background:#3d1515;color:#fca5a5">Flag reason</th>
        <th>Status</th>
        <th style="width:140px;position:sticky;right:0;background:#1e2f47;z-index:8;border-left:2px solid #162236">Actions</th>
    </tr></thead>
            <tbody id="p2-body">
            @for (var i = 0; i < flagRows.Count; i++)
        {
            var r = flagRows[i];
            var canEdit = !r.FlagReason.Contains("ACN not found") && !r.FlagReason.Contains("not in this Excel");
            var rowKey = string.IsNullOrWhiteSpace(r.RowKey) ? $"r{i}_{r.ControlNo}" : r.RowKey;
            <tr class="p2-row"
            data-ctrlno="@r.ControlNo"
            data-origctrlno="@r.ControlNo"
            data-rowid="@rowKey" 
            data-acn="@r.AnimalControlNumber"
            data-fileacn="@r.NewAnimalControlNumber"
            data-type="@r.FileType"
            data-sex="@r.FileSex"
            data-condemned="@(r.IsCondemned ? "1" : "0")"
                data-reason="@r.FlagReason.ToLower()" data-fixed="0" data-saved="0" data-loaded="0">
                <td style="text-align:center;position:sticky;left:0;z-index:6;background:var(--bg-card,#fff)">
                        <input type="checkbox" class="p2-chk" data-ctrlno="@r.ControlNo" onchange="updateP2Counts()" disabled>
                    </td>

                    <td class="mono p2-acn-cell"
                        id="acn-@rowKey"
                        title="@r.AnimalControlNumber"
                        style="position:sticky;left:32px;z-index:6;background:var(--bg-card,#fff);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px">
                        @r.AnimalControlNumber
                    </td>

                    <td title="@(r.FileLot ?? "—")"
                        style="position:sticky;left:152px;z-index:6;background:var(--bg-card,#fff);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:70px">
                        @(r.FileLot ?? "—")
                    </td>

                    <td title="@(r.FileBackTag ?? "—")"
                        style="position:sticky;left:222px;z-index:6;background:var(--bg-card,#fff);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px">
                        @(r.FileBackTag ?? "—")
                    </td>

