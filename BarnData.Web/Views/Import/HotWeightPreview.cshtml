//  Candidate picker  page-level modal 
var _modalRowId = null;
var _modalPicked = null;

function openCandModal(rowId) {
    var link = document.getElementById('flnk-' + rowId);
    if (!link) return;
    // Already confirmed — don't reopen
    var tr = document.querySelector('.p2-row[data-rowid="' + rowId + '"]');
    if (tr && tr.dataset.confirmed === '1') return;

    var raw = link.getAttribute('data-cands') || '[]';
    var cands;
    try { cands = JSON.parse(raw); } catch(e) { cands = []; }
    if (!cands.length) return;

    _modalRowId  = rowId;
    _modalPicked = null;

    // Build header
    var cols = ['','\u0394 Wt','CtrlNo','ACN','Tag1','Tag2','Tag3','Vendor','LiveWt','LiveRate',
                'Type','Type2','PurchType','PurchDate','Grade','Grade2','HS','Program',
                'Origin','State','Buyer','Vet','KillStatus','Comment','Created'];
    var thead = document.getElementById('cand-modal-head');
    var th = '<tr style="background:#1e2f47;position:sticky;top:0">';
    cols.forEach(function(c,i){
        var col = i===7||i===11||i===12||i===23 ? 'max-width:110px' : '';
        th += '<th style="padding:5px 8px;color:' + (i===1?'#9ae6b4':'#fff') + ';text-align:left;white-space:nowrap;font-size:11px;font-weight:500;'+col+'">' + c + '</th>';
    });
    th += '</tr>';
    thead.innerHTML = th;

    // Build rows
    var tbody = document.getElementById('cand-modal-body');
    tbody.innerHTML = '';
    cands.forEach(function(c, idx) {
        var diff = c.WeightDiff || 0;
        var dStyle = diff <= 50  ? 'background:#dcfce7;color:#15803d' :
                     diff <= 150 ? 'background:#fef3c7;color:#92400e' :
                                   'background:#fee2e2;color:#b91c1c';
        var rowBg = idx % 2 === 0 ? '' : 'background:#f8fafc';
        var tr2 = document.createElement('tr');
        tr2.id = 'cmi-' + rowId + '-' + c.ControlNo;
        tr2.setAttribute('style', rowBg + ';cursor:pointer;border-bottom:.5px solid #e2e8f0');
        tr2.onclick = function(){ selectModalRow(c.ControlNo, c.AnimalControlNumber); };

        var cells = [
            '<input type="radio" name="cmi-radio" style="cursor:pointer">',
            diff > 0 ? '<span style="border-radius:3px;padding:1px 5px;font-size:10.5px;font-weight:700;' + dStyle + '">&Delta; ' + diff.toFixed(0) + ' lbs</span>' : '&mdash;',
            '<strong style="font-family:monospace">' + c.ControlNo + '</strong>',
            '<span style="font-family:monospace;color:#1d4ed8">' + (c.AnimalControlNumber||'&mdash;') + '</span>',
            '<strong>' + (c.Tag1||'&mdash;') + '</strong>',
            c.Tag2||'&mdash;', c.Tag3||'&mdash;',
            '<span title="'+(c.VendorName||'')+'" style="display:block;max-width:110px;overflow:hidden;text-overflow:ellipsis">' + (c.VendorName||'&mdash;') + '</span>',
            c.LiveWeight > 0 ? '<strong>' + c.LiveWeight.toLocaleString() + '</strong>' : '&mdash;',
            c.LiveRate > 0 ? '$' + c.LiveRate.toFixed(4) : '&mdash;',
            c.AnimalType||'&mdash;', c.AnimalType2||'&mdash;',
            '<span title="'+(c.PurchaseType||'')+'" style="display:block;max-width:110px;overflow:hidden;text-overflow:ellipsis">' + (c.PurchaseType||'&mdash;') + '</span>',
            c.PurchaseDate||'&mdash;',
            '<strong>' + (c.Grade||'&mdash;') + '</strong>',
            c.Grade2||'&mdash;',
            c.HealthScore != null ? c.HealthScore : '&mdash;',
            c.ProgramCode||'&mdash;', c.Origin||'&mdash;', c.State||'&mdash;',
            '<span title="'+(c.BuyerName||'')+'" style="display:block;max-width:80px;overflow:hidden;text-overflow:ellipsis">' + (c.BuyerName||'&mdash;') + '</span>',
            c.VetName||'&mdash;', c.KillStatus||'&mdash;',
            '<span title="'+(c.Comment||'')+'" style="display:block;max-width:110px;overflow:hidden;text-overflow:ellipsis">' + (c.Comment||'&mdash;') + '</span>',
            '<span style="color:#64748b">' + (c.CreatedAt||'&mdash;') + '</span>'
        ];
        tr2.innerHTML = cells.map(function(v){ return '<td style="padding:5px 8px;vertical-align:middle">'+v+'</td>'; }).join('');
        tbody.appendChild(tr2);
    });

    document.getElementById('cand-modal-title').textContent = cands.length + ' animals match — click a row to select, then confirm';
    document.getElementById('cand-modal-confirm').disabled = true;
    document.getElementById('cand-modal-hint').textContent = 'Click a row to select, then click Confirm';
    document.getElementById('cand-modal-hint').style.color = '#64748b';
    document.getElementById('cand-modal-overlay').style.display = 'block';
    document.body.style.overflow = 'hidden';
}

function selectModalRow(candCtrlNo, candAcn) {
    _modalPicked = { ctrlNo: candCtrlNo, acn: candAcn };
    document.querySelectorAll('[id^="cmi-' + _modalRowId + '-"]').forEach(function(r){ r.style.background=''; r.style.outline=''; });
    var row = document.getElementById('cmi-' + _modalRowId + '-' + candCtrlNo);
    if (row) {
        row.style.background = '#eff6ff';
        row.style.outline = '2px solid #2563eb';
        row.querySelector('input[type=radio]').checked = true;
    }
    document.getElementById('cand-modal-confirm').disabled = false;
    document.getElementById('cand-modal-hint').textContent = 'ACN ' + candAcn + ' selected — click Confirm';
    document.getElementById('cand-modal-hint').style.color = '#15803d';
}

function closeCandModal() {
    document.getElementById('cand-modal-overlay').style.display = 'none';
    document.body.style.overflow = '';
    _modalRowId = null;
    _modalPicked = null;
}

function confirmModalPick() {
    if (!_modalPicked || !_modalRowId) return;
    var rowId = _modalRowId;
    var sel   = _modalPicked;
    var tr = document.querySelector('.p2-row[data-rowid="' + rowId + '"]');
    if (!tr) { closeCandModal(); return; }

    // ACN precedence (most authoritative least):
    //   1. File ACN (the Excel row's ACN column, if any) - this is what the user is trying to write
    //   2. The picked candidate's existing ACN in the DB (picking an already-assigned animal)
    //   3. Whatever was already on the row's data-acn attribute (the initial server-rendered value)
    // We keep data-fileacn as a stable "Excel intent" and only update data-acn when we actually
    // have a better value - NEVER overwrite it with an empty string.
    var pickedAcn   = (sel.acn || '').trim();
    var existingFileAcn = (tr.dataset.fileacn || '').trim();
    var existingRowAcn  = (tr.dataset.acn     || '').trim();
    // The ACN we want persisted to DB for this ControlNo:
    var acnToPersist = existingFileAcn || pickedAcn || existingRowAcn;

    tr.dataset.ctrlno    = String(sel.ctrlNo);
    // Only update data-acn if we have something real; don't wipe it with ""
    if (acnToPersist) tr.dataset.acn = acnToPersist;
    // If fileacn was empty but we picked a candidate with an ACN, remember it as the file intent
    // so saveFixedToDB (which reads fileacn first) sends it to the server.
    if (!existingFileAcn && pickedAcn) tr.dataset.fileacn = pickedAcn;
    tr.dataset.confirmed = '1';

    var chk = tr.querySelector('.p2-chk');
    if (chk) chk.dataset.ctrlno = String(sel.ctrlNo);

    var acnCell = document.getElementById('acn-' + rowId);
    if (acnCell) acnCell.textContent = acnToPersist || 'Unassigned';

    var link = document.getElementById('flnk-' + rowId);
    if (link) {
        link.textContent = acnToPersist
            ? 'Matched to ControlNo ' + sel.ctrlNo + ' — will write ACN ' + acnToPersist + ' ✓'
            : 'Assigned to ControlNo ' + sel.ctrlNo + ' (no ACN) ✓';
        link.style.color = '#15803d';
        link.style.textDecoration = 'none';
        link.style.cursor = 'default';
        link.removeAttribute('onclick');
    }

    closeCandModal();
    if (typeof onFieldChange === 'function') onFieldChange(tr);
    else if (typeof updateP2Counts === 'function') updateP2Counts();
}

// Close modal on overlay click — runs once, inline after modal div is in DOM
(function() {
    var overlay = document.getElementById('cand-modal-overlay');
    if (overlay) overlay.addEventListener('click', function(e){ if(e.target===overlay) closeCandModal(); });
})();
// Close on ESC
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeCandModal(); });
</script>
