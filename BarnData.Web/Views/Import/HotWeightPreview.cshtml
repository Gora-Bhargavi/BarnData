<script>
const BULL_GRADE_SET = new Set(['BB','LB','UB','FB']);
const COW_GRADE_SET  = new Set(['CN','SH','CT','B1','B2','BR']);

function normalizeSexCode(sex){
const s = (sex || '').toUpperCase().trim();
if (s === 'B') return 'B';
if (s === 'F') return 'F';
return null;
}

function normalizeTypeGroup(type){
const t = (type || '').toUpperCase().trim();
if (t === 'BULL') return 'BULL';
if (t === 'DCOW' || t === 'BCOW') return 'COW';
return null;
}

function resolveGradeRulesForRow(tr){
const sexCode = normalizeSexCode(tr.dataset.sex || '');
const typeGroup = normalizeTypeGroup(tr.dataset.type || '');
const mismatch = !!(sexCode && typeGroup && ((sexCode === 'B' && typeGroup !== 'BULL') || (sexCode === 'F' && typeGroup !== 'COW')));

if (sexCode === 'B') return { allowed: BULL_GRADE_SET, mismatch: mismatch, sexCode: 'B', typeCode: typeGroup || '-' };
if (sexCode === 'F') return { allowed: COW_GRADE_SET, mismatch: mismatch, sexCode: 'F', typeCode: typeGroup || '-' };
if (typeGroup === 'BULL') return { allowed: BULL_GRADE_SET, mismatch: mismatch, sexCode: '-', typeCode: 'BULL' };
if (typeGroup === 'COW') return { allowed: COW_GRADE_SET, mismatch: mismatch, sexCode: '-', typeCode: 'COW' };

return { allowed: null, mismatch: mismatch, sexCode: sexCode || '-', typeCode: typeGroup || '-' };
}
var AF_HW = '';   // set in DOMContentLoaded after DOM is ready

//  Tab switching
function switchTab(n) {
    for (var i = 0; i < 4; i++) {
        var p = document.getElementById('panel' + i);
        var t = document.getElementById('tab'   + i);
        if (p) p.style.display = i === n ? '' : 'none';
        if (t) t.classList.toggle('active', i === n);
    }
}

//  Select all helpers 
function selAll(prefix, val) {
    document.querySelectorAll('.' + prefix + '-chk:not(:disabled)').forEach(function(c){c.checked = val;});
    var all = document.getElementById(prefix + '-all');
    if (all) all.checked = val;
    updSel(prefix);
}
function selAllFixed() {
    document.querySelectorAll('.p2-chk:not(:disabled)').forEach(function(c){c.checked=true;});
    updateP2Counts();
}
function selAllVisible(val) {
    document.querySelectorAll('.p2-chk:not(:disabled)').forEach(function(c){
        if (c.closest('tr').style.display !== 'none') c.checked = val;
    });
    updateP2Counts();
}

//  Update selection counts 
function updSel(prefix) {
    var n = document.querySelectorAll('.' + prefix + '-chk:checked').length;
    var el = document.getElementById(prefix + '-sel');
    if (el) el.textContent = n;
    if (prefix === 'p1') {
        var tot = document.querySelectorAll('.p1-chk').length;
        var all = document.getElementById('p1-all');
        if (all) { all.indeterminate = n>0 && n<tot; all.checked = n===tot; }
    }
    if (prefix === 'p2') {
        var btn = document.getElementById('p2-load');
        var hint = document.getElementById('p2-hint');
        if (btn)  btn.disabled = n === 0;
        if (hint) hint.textContent = n === 0 ? '0 selected — none will be overwritten' : n + ' will be overwritten';
    }
}
function updateP2Counts() {
    var sel   = document.querySelectorAll('.p2-chk:checked').length;
    var fixed = document.querySelectorAll('.p2-row[data-fixed="1"]').length;
    // Count active rows (not yet saved or loaded) for tab badge
    var active = document.querySelectorAll('.p2-row:not([data-saved="1"]):not([data-loaded="1"])').length;
    var selEl = document.getElementById('p2-sel');
    var fixEl = document.getElementById('p2-fixed-count');
    if (selEl) selEl.textContent = sel;
    if (fixEl) fixEl.textContent = fixed;
    // Update tab badge and stat card
    var tabBadge = document.getElementById('cnt2');
    if (tabBadge) tabBadge.textContent = active;
    var statN = document.getElementById('sc2-n');
    if (statN) statN.textContent = active;
    var loadBtn = document.getElementById('p2-load-btn');
    var saveBtn = document.getElementById('p2-save-btn');
    if (loadBtn) loadBtn.disabled = sel === 0;
    if (saveBtn) saveBtn.disabled = sel === 0;
}

//  Flagged row inline validation 
function onFieldChange(tr) {
    if (!tr) return;
    var s1    = parseFloat(tr.querySelector('.f-side1')?.value) || 0;
    var s2    = parseFloat(tr.querySelector('.f-side2')?.value) || 0;
    var hotCell = tr.querySelector('.f-hot-total');
    if (hotCell) hotCell.textContent = (s1 + s2).toFixed(1);
    var grade = (tr.querySelector('.f-grade')?.value || '').toUpperCase();
    var hs    = parseInt(tr.querySelector('.f-hs')?.value) || 0;
    var rule  = resolveGradeRulesForRow(tr);
    var stEl  = tr.querySelector('.f-status');
    var chk   = tr.querySelector('.p2-chk');

    // Detect condemned. Server-side: Grade or Grade2 starts with X — IsCondemned
    // is rendered onto the row as data-condemned="1". Client-side fallback: if
    // operator changes the Grade dropdown to an X-code, treat as condemned too.
    // Condemned animals don't have carcass weight, conventional grade, or HS,
    // so the standard Side1/Side2/Grade/HS validators would falsely flag them.
    var isCondemned = (tr.dataset.condemned === '1')
                      || (grade && grade.charAt(0) === 'X');

    // Validate — collect issues for review; do not hard-block Save to DB.
    var errors = [];
    var warnings = [];
    if (!isCondemned) {
        if (s1 <= 0) errors.push('Side1 required');
        if (s2 <= 0) errors.push('Side2 required');
        if (!grade) {
            errors.push('Grade required');
        } else if (rule.allowed && !rule.allowed.has(grade)) {
            errors.push('Invalid grade for Sex/Type rule');
        }
        if (hs < 1 || hs > 5) errors.push('HS must be 1–5');
    }
    if (rule.mismatch) {
        warnings.push('Sex and Type mismatch: Sex=' + rule.sexCode + ', Type=' + rule.typeCode);
    }

    var ok = errors.length === 0;
    var reviewOnly = warnings.length > 0;
    tr.classList.toggle('p2-fixed-row', ok);
    tr.dataset.fixed = ok ? '1' : '0';

    if (stEl) {
        if (!ok) {
            stEl.textContent = errors[0] || 'Flagged';
            stEl.style.cssText = 'background:#fee2e2;color:#b91c1c;font-size:11px;white-space:nowrap;border-radius:4px;padding:1px 6px;font-weight:600';
        } else if (isCondemned) {
            // Condemned rows go to Ready as-is — no carcass weight needed.
            stEl.textContent = '🚫 Condemned — ready';
            stEl.style.cssText = 'background:#fef2f2;color:#991b1b;font-size:11px;white-space:nowrap;border-radius:4px;padding:1px 6px;font-weight:600';
        } else if (reviewOnly) {
            stEl.textContent = warnings[0];
            stEl.style.cssText = 'background:#fffbeb;color:#92400e;font-size:11px;white-space:nowrap;border-radius:4px;padding:1px 6px;font-weight:600';
        } else {
            var hw = (s1 + s2).toFixed(1);
            stEl.textContent = 'Ready — ' + hw + ' lbs';
            stEl.style.cssText = 'background:#eff6ff;color:#1e40af;font-size:11px;white-space:nowrap;border-radius:4px;padding:1px 6px;font-weight:600';
        }
    }
    if (chk) chk.disabled = false;
    // Enable/disable the per-row Load button
    var rowLoadBtn = tr.querySelector('.row-load-btn');
    if (rowLoadBtn) rowLoadBtn.disabled = !ok;
    updateP2Counts();
}

// Filter flagged rows 
function filterFlagged() {
    var q = (document.getElementById('p2-filter')?.value || '').toLowerCase();
    document.querySelectorAll('.p2-row').forEach(function(row) {
        var acn    = (row.dataset.acn    || '').toLowerCase();
        var reason = (row.dataset.reason || '').toLowerCase();
        row.style.display = !q || acn.includes(q) || reason.includes(q) ? '' : 'none';
    });
    updateP2Counts();
}

// Delete a single row 
function deleteRow(btn) {
    var tr = btn.closest('tr');
    if (!tr) return;
    // Two-click confirm — no browser dialog (can be silently blocked)
    if (btn.dataset.confirming === '1') {
        tr.remove();
        updateP2Counts();
        return;
    }
    btn.dataset.confirming = '1';
    var orig = btn.textContent;
    var origStyle = btn.getAttribute('style') || '';
    btn.textContent = 'Confirm?';
    btn.style.cssText = 'background:#b91c1c;color:#fff;border:1px solid #991b1b;font-size:11px;padding:2px 8px;border-radius:4px;cursor:pointer;font-weight:600';
    setTimeout(function() {
        if (btn.dataset.confirming === '1') {
            btn.dataset.confirming = '0';
            btn.textContent = orig;
            btn.setAttribute('style', origStyle);
        }
    }, 3000);
}

// Load a single fixed row into Mark as Killed
async function loadSingleRow(btn) {
    var tr = btn.closest('tr');
    if (!tr || tr.dataset.fixed !== '1') { alert('Fix all fields first.'); return; }

    var s1     = parseFloat(tr.querySelector('.f-side1')?.value) || 0;
    var s2     = parseFloat(tr.querySelector('.f-side2')?.value) || 0;
    var grade  = tr.querySelector('.f-grade')?.value || '';
    var hs     = parseInt(tr.querySelector('.f-hs')?.value) || 0;
    var ctrlno = parseInt(tr.dataset.ctrlno || '0');

    if (!ctrlno || ctrlno <= 0) {
        alert('This row is not linked to a valid DB record yet. Pick a candidate first.');
        return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving…';

    try {
        var res = await fetch('/Import/SaveEditsApi', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': AF_HW },
            body: JSON.stringify({
                rows: [{
                    controlNo: ctrlno,
                    originalControlNo: parseInt(tr.dataset.origctrlno || '0'),
                    hotWeight: parseFloat((s1 + s2).toFixed(1)),
                    grade: grade,
                    healthScore: hs,
                    liveWeight: 0,
                    isCondemned: false,
                    animalControlNumber: (tr.dataset.fileacn || tr.dataset.acn || '').trim(),
                    killDate: '',
                    state: '',
                    vetName: '',
                    officeUse2: '',
                    comment: '',
                    purchaseType: ''
                }]
            })
        });

        var data = await res.json();
        var saved = Number(data.saved || data.count || 0);

        if (data.success && saved > 0) {
            tr.dataset.loaded = '1';
            tr.dataset.fixed  = '0';
            tr.style.opacity  = '0.55';
            tr.classList.remove('p2-fixed-row');

            var stEl = tr.querySelector('.f-status');
            if (stEl) {
                stEl.textContent = 'Loaded ✓';
                stEl.style.cssText = 'background:#dcfce7;color:#166534;font-size:11px;border-radius:4px;padding:1px 6px;font-weight:600';
            }

            var chk = tr.querySelector('.p2-chk');
            if (chk) { chk.checked = false; chk.disabled = true; }

            tr.querySelectorAll('.hw-edit-input, .f-side1, .f-side2, .f-grade, .f-hs').forEach(function(i) {
                i.disabled = true;
            });

            btn.textContent = 'Going to Mark as Killed…';
            btn.style.cssText = 'background:#f0fdf4;color:#166534;border:1px solid #86efac;font-size:11px;padding:2px 8px;border-radius:4px;cursor:default;font-weight:600';
            btn.disabled = true;

            updateP2Counts();

            document.getElementById('hw-load-ids').value   = String(ctrlno);
            document.getElementById('hw-fixed-json').value = JSON.stringify([{
                rowKey: tr.dataset.rowid || '',
                controlNo: ctrlno,
                animalControlNumber: (tr.dataset.fileacn || tr.dataset.acn || '').trim(),
                side1: s1,
                side2: s2,
                grade: grade,
                healthScore: hs
            }]);
            setTimeout(function() {
                document.getElementById('hw-load-form').submit();
            }, 100);
            
        } else {
            alert('Save failed: ' + (data.message || 'No records were updated.'));
            btn.disabled = false;
            btn.textContent = 'Load';
        }
    } catch (e) {
        alert('Error: ' + e.message);
        btn.disabled = false;
        btn.textContent = 'Load';
    }
}

//  Delete selected flagged rows 
function deleteSelectedFlagged() {
    var chks = document.querySelectorAll('.p2-chk:checked');
    if (!chks.length) { alert('Select at least one row to delete.'); return; }
    if (!confirm('Remove ' + chks.length + ' row(s) from this session preview? This does not affect the database.')) return;
    chks.forEach(function(c) { c.closest('tr').remove(); });
    updateP2Counts();
}

// Load selected flagged rows into Mark as Killed 
function loadSelectedFlagged() {
    var fixed = [...document.querySelectorAll('.p2-row[data-fixed="1"] .p2-chk:checked')];
    if (!fixed.length) { alert('Select fixed rows first.'); return; }

    var ids = fixed
        .map(function(c){ return c.closest('tr')?.dataset.ctrlno || ''; })
        .filter(function(v){ return !!v; })
        .join(',');

    var data = fixed.map(function(c) {
        var tr = c.closest('tr');
        var s1 = parseFloat(tr.querySelector('.f-side1')?.value) || 0;
        var s2 = parseFloat(tr.querySelector('.f-side2')?.value) || 0;
        return {
            rowKey: tr.dataset.rowid || '',
            controlNo: parseInt(tr.dataset.ctrlno || '0'),
            animalControlNumber: (tr.dataset.fileacn || tr.dataset.acn || '').trim(),
            side1: s1,
            side2: s2,
            grade: tr.querySelector('.f-grade')?.value || '',
            healthScore: parseInt(tr.querySelector('.f-hs')?.value) || 0
        };
    });

    document.getElementById('hw-load-ids').value   = ids;
    document.getElementById('hw-fixed-json').value = JSON.stringify(data);
    document.getElementById('hw-load-form').submit();
}

//  Load tab 1 selected rows 
function loadSelected(prefix) {
    var ids = [...document.querySelectorAll('.'+prefix+'-chk:checked')]
    .map(function(c){return c.dataset.ctrlno;}).filter(Boolean).join(',');
    if (!ids) { alert('Select at least one row to load.'); return; }
    document.getElementById('hw-load-ids').value = ids;
    document.getElementById('hw-fixed-json').value = '';
    document.getElementById('hw-load-form').submit();
}

// Save fixed flagged rows directly to DB 
async function saveFixedToDB() {
    var fixed = [...document.querySelectorAll('.p2-row[data-fixed="1"] .p2-chk:checked')];
    if (!fixed.length) { alert('Select at least one row to save.'); return; }

    var rows = fixed.map(function(chk) {
        var tr = chk.closest('tr');
        var s1 = parseFloat(tr.querySelector('.f-side1')?.value) || 0;
        var s2 = parseFloat(tr.querySelector('.f-side2')?.value) || 0;
        return {
            rowKey: tr.dataset.rowid || '',
            controlNo: parseInt(tr.dataset.ctrlno || '0'),
            hotWeight: parseFloat((s1 + s2).toFixed(1)),
            grade: tr.querySelector('.f-grade')?.value || '',
            healthScore: parseInt(tr.querySelector('.f-hs')?.value) || 0,
            liveWeight: 0,
            isCondemned: false,
            animalControlNumber: (tr.dataset.fileacn || tr.dataset.acn || '').trim(),
            killDate: '',
            state: '',
            vetName: '',
            officeUse2: '',
            comment: '',
            purchaseType: ''
        };
    });

    var invalidRows = rows.filter(function(r) { return !r.controlNo || r.controlNo <= 0; });
    if (invalidRows.length) {
        alert('One or more selected rows are not linked to a valid DB record yet. Pick a candidate first.');
        return;
    }

    var saveBtn = document.getElementById('p2-save-btn');
    if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = 'Saving…'; }

    try {
        var res = await fetch('/Import/SaveEditsApi', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': AF_HW },
            body: JSON.stringify({ rows: rows })
        });
        var data = await res.json();
        var saved = Number(data.saved || data.count || 0);

        if (data.success && saved > 0) {
            var summary = rows.map(function(r) {
                var row = fixed
                    .map(function(c){ return c.closest('tr'); })
                    .find(function(tr){ return parseInt(tr.dataset.ctrlno || '0') === r.controlNo; });
                var acn = row?.dataset.acn || '';
                return 'ACN ' + acn + ' — HotWeight ' + r.hotWeight + ' lbs, Grade ' + r.grade + ', HS ' + r.healthScore;
            }).join(' · ');

            document.getElementById('save-confirm-msg').textContent =
                saved + ' record' + (saved !== 1 ? 's' : '') + ' updated: ' + summary + '.';
            document.getElementById('save-confirm').style.display = 'block';
            window.scrollTo({ top: 0, behavior: 'smooth' });

            fixed.forEach(function(chk) {
                var tr = chk.closest('tr');
                tr.dataset.saved = '1';
                tr.dataset.fixed = '0';
                tr.classList.remove('p2-fixed-row');

                var stEl = tr.querySelector('.f-status');
                if (stEl) {
                    stEl.textContent = 'Saved to DB';
                    stEl.style.cssText = 'background:#dcfce7;color:#166534;font-size:11px;border-radius:4px;padding:1px 6px;font-weight:600';
                }

                chk.disabled = true;
                chk.checked = false;
                tr.querySelectorAll('.hw-edit-input').forEach(function(inp) { inp.disabled = true; });
            });

            updateP2Counts();
        } else {
            alert('Save failed: ' + (data.message || 'No records were updated.'));
        }
    } catch (e) {
        alert('Error: ' + e.message);
    } finally {
        if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save to DB →'; }
    }
}

