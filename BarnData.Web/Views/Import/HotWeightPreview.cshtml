                            <button type="button" class="row-load-btn btn btn-sm"
                                    style="background:#f0fdf4;color:#15803d;border-color:#86efac;font-size:11px;padding:2px 8px;margin-right:3px"
                                    disabled
                                    onclick="loadSingleRow(this)">Load</button>
                        }
                        <button type="button" class="btn btn-sm"
                                style="background:#fef2f2;color:#b91c1c;border-color:#fca5a5;font-size:11px;padding:2px 8px"
                                onclick="deleteRow(this)">Delete</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
