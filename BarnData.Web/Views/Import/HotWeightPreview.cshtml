                        <input type="number" class="f-side2 hw-edit-input" step="0.1" min="0"
                            value="@(r.Side2?.ToString("0.0") ?? "")" placeholder="lbs"
                            oninput="onFieldChange(this.closest('tr'))"
                            style="width:78px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px" />
                    </td>
                    <td class="text-right mono f-hot-total">@(((r.Side1 ?? 0m) + (r.Side2 ?? 0m)).ToString("N1"))</td>
                    <td>
                        <select class="f-grade hw-edit-input" onchange="onFieldChange(this.closest('tr'))"
                                style="width:68px;padding:3px 4px;font-size:12px;border:1px solid var(--gray3);border-radius:4px">
                            <option value="">—</option>
                            @foreach (var g in validGrades)
                            {
                                <option value="@g" selected="@(g == r.NewGrade ? "selected" : null)">@g</option>
                            }
                        </select>
                    </td>
                    <td>@(r.NewGrade2 ?? "—")</td>
                    <td>
                        <input type="number" class="f-hs hw-edit-input" min="1" max="5" placeholder="1-5"
                            value="@(r.NewHealthScore?.ToString() ?? "")"
                            oninput="onFieldChange(this.closest('tr'))"
                            style="width:50px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px" />
                    </td>
                }
                else
                {
                    <td class="text-right mono" style="color:var(--text3)">@(r.Side1?.ToString("N1") ?? "—")</td>
                    <td class="text-right mono" style="color:var(--text3)">@(r.Side2?.ToString("N1") ?? "—")</td>
                    <td class="text-right mono f-hot-total">@(((r.Side1 ?? 0m) + (r.Side2 ?? 0m)).ToString("N1"))</td>
                    <td style="color:var(--text3)">@(r.NewGrade ?? "—")</td>
                    <td style="color:var(--text3)">@(r.NewGrade2 ?? "—")</td>
                    <td style="color:var(--text3)">@(r.NewHealthScore?.ToString() ?? "—")</td>
                }
                    <td style="font-size:11px;max-width:220px" title="@r.FlagReason">
                        @if (r.Candidates != null && r.Candidates.Any())
                        {
                            var _cJson = System.Text.Encodings.Web.HtmlEncoder.Default.Encode(
                                System.Text.Json.JsonSerializer.Serialize(r.Candidates));
                            <span class="cand-flag-link"
                                  id="flnk-@rowKey"
                                  onclick="openCandModal('@rowKey')"
                                  data-cands="@Html.Raw(_cJson)">
                                @r.FlagReason — @r.Candidates.Count candidates ▸ pick
                            </span>
                        }
                        else
                        {
                            <span style="color:#b91c1c">@r.FlagReason</span>
                        }
                    </td>
                    <td><span class="f-status badge" style="background:#fee2e2;color:#b91c1c;font-size:11px;white-space:nowrap">Flagged</span></td>
                    <td class="actions-cell" style="white-space:nowrap;position:sticky;right:0;z-index:2;background:var(--bg, #fff);border-left:2px solid var(--gray3);padding:5px 8px">
