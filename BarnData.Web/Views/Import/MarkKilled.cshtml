@model BarnData.Web.Models.MarkKilledViewModel
@{
    ViewData["Title"]    = "Mark animals as killed";
    ViewData["Subtitle"] = "Select animals, enter kill data, then submit";
    var todayStr = DateTime.Today.ToString("yyyy-MM-dd");
    var grades   = new[] { "", "CT","B1","B2","CN","LB","UB","BB","BR","SL" };
}

<div class="alert alert-info" style="margin-bottom:14px">
    <strong>How this works:</strong>
    Update inline fields, then click <strong>Save edits</strong> to store partial changes without marking killed.
    For consignment rows, if Hot Wt is entered then Live Wt is required and Hot Wt cannot be greater than Live Wt.
    Use row checkboxes only for animals you want to finalize, then click <strong>Mark selected as killed</strong>.
</div>

<form method="post" asp-action="MarkKilled">
    @Html.AntiForgeryToken()

    <input type="hidden" name="VendorId" value="@Model.VendorId" />

    <!-- Kill date + vendor filter + actions -->
    <div class="form-section" style="margin-bottom:12px">
        <div style="display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap">
            <div class="field">
                <label class="field-label">Kill date <span class="req">*</span></label>
                <input name="killDate" type="date" value="@todayStr"
                       class="form-control" style="width:180px" />
            </div>
            <div class="field">
                <label class="field-label">Filter by vendor</label>
                <select asp-for="VendorId" asp-items="Model.VendorList"
                        class="form-control" style="width:240px"
                        onchange="window.location='/Import/MarkKilled?vendorId='+this.value">
                    <option value="">All vendors (@Model.Animals.Count pending)</option>
                </select>
            </div>
            <div style="display:flex;gap:8px;padding-bottom:2px">
                <button type="submit" formaction="@Url.Action("SaveMarkKilledEdits","Import")" class="btn btn-secondary">Save edits</button>
                <button type="button" onclick="selectAll(true)"  class="btn btn-secondary btn-sm">Select all</button>
                <button type="button" onclick="selectAll(false)" class="btn btn-secondary btn-sm">Deselect all</button>
                <button type="submit" class="btn btn-primary">Mark selected as killed →</button>
            </div>
        </div>
    </div>

    @if (!Model.Animals.Any())
    {
        <div class="empty-state">
            <div class="empty-title">No pending animals</div>
            <div class="empty-sub">All animals have a kill date, or no bills have been imported yet.</div>
            <div style="display:flex;gap:8px;justify-content:center;margin-top:12px">
                <a asp-controller="Import" asp-action="SaleBill" class="btn btn-primary">Import a sale bill</a>
                <a asp-controller="Report" asp-action="Tally" class="btn btn-secondary">View tally report</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-card">
            <div style="padding:10px 14px;border-bottom:1px solid var(--gray3);display:flex;justify-content:space-between;align-items:center;font-size:12.5px;background:var(--gray1)">
                <span><strong>@Model.Animals.Count</strong> pending animals</span>
                <span id="selectedCount" style="font-size:11.5px;color:var(--blue);font-weight:500">0 selected</span>
            </div>

            <!-- Top scrollbar mirror -->
            <div id="scrollTop" style="overflow-x:auto;overflow-y:hidden;border-bottom:1px solid var(--gray3)">
                <div id="scrollTopInner" style="height:1px"></div>
            </div>

            <!-- Main scrollable table -->
            <div id="scrollMain" style="overflow-x:auto">
                <table class="data-table" id="mainTable" style="min-width:2400px;font-size:12px;">
                    <thead>
                        <tr>
                            <th style="width:36px;position:sticky;left:0;z-index:3;background:var(--gray2)">
                                <input type="checkbox" id="selectAllChk" onchange="selectAll(this.checked)" />
                            </th>
                            <th class="sticky-col sticky-col-1" style="min-width:65px">Ctrl No.</th>
                            <th class="sticky-col sticky-col-2" style="min-width:130px">Vendor</th>
                            <th class="sticky-col sticky-col-3" style="min-width:90px">Tag 1</th>
                            <th class="sticky-col sticky-col-4" style="min-width:90px">Tag 2</th>
                            <th style="min-width:95px">Animal Type</th>
                            <th style="min-width:95px">Purchase Type</th>
                            <th style="min-width:95px">Purchase Date</th>
                            <th class="text-right" style="min-width:75px">Live Wt</th>
                            <th class="text-right" style="min-width:75px">Live Rate</th>
                            <th class="sticky-col sticky-col-5" style="min-width:110px">Animal Ctrl No.</th>
                            <th style="min-width:70px">Tag 3</th>
                            <th style="min-width:45px">State</th>
                            <th style="min-width:100px">Buyer</th>
                            <th style="min-width:100px">Animal Type 2</th>
                            <th style="min-width:100px">Vet Name</th>
                            <th style="min-width:120px">Office Use 2</th>
                            <th style="min-width:160px">Comments</th>
                            <th style="min-width:95px;background:#f0fdf4;color:#15803d">Animal Ctrl No ✎</th>
                            <th style="min-width:95px;background:#f0fdf4;color:#15803d">State ✎</th>
                            <th style="min-width:130px;background:#f0fdf4;color:#15803d">Vet Name ✎</th>
                            <th style="min-width:140px;background:#f0fdf4;color:#15803d">Office Use 2 ✎</th>
                            <th style="min-width:190px;background:#f0fdf4;color:#15803d">Comments ✎</th>
                            <th class="sticky-col sticky-col-6" style="min-width: 105px;background:#f0fdf4;color:#15803d">Live Wt ✎</th>
                            <th style="min-width:95px;background:#f0fdf4;color:#15803d">Kill Date ✎</th>
                            <th style="min-width:95px;background:#f0fdf4;color:#15803d">Hot Wt ✎</th>
                            <th style="min-width:90px;background:#f0fdf4;color:#15803d">Grade ✎</th>
                            <th style="min-width:75px;background:#f0fdf4;color:#15803d">HS ✎</th>
                            <th style="min-width:95px;background:#fef2f2;color:#b91c1c">Condemned ✎</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.Animals)
                        {
                            <tr class="animal-row" id="row-@a.ControlNo">
                                <td style="position:sticky;left:0;z-index:2;background:#fff">
                                    <input type="checkbox"
                                           name="selectedIds"
                                           value="@a.ControlNo"
                                           class="animal-chk"
                                           onchange="highlightRow(this); updateCount()" />
                                           <input type="hidden" name="origLiveWeight_@a.ControlNo" value="@a.LiveWeight.ToString("0.0")" />
                                           <input type="hidden" name="purchaseType_@a.ControlNo" value="@a.PurchaseType" />
                                           <input type ="hidden" name="allIds" value="@a.ControlNo" />
                                           <input type ="hidden" name="origAnimalCtrlNo_@a.ControlNo" value="@a.AnimalControlNumber" />
                                           <input type="hidden" name="origCondemned_@a.ControlNo" value="@(a.IsCondemned ? "true" : "false")" />
                                           
                                </td>
                                <td class="mono sticky-col sticky-col-1">@a.ControlNo</td>
                                <td class="sticky-col sticky-col-2" style="font-weight:500">@a.VendorName</td>
                                <td class="mono sticky-col sticky-col-3">@a.Tag1</td>
                                <td class="mono sticky-col sticky-col-4">@(a.Tag2 ?? "—")</td>
                                <td>@a.AnimalType</td>
                                <td>
                                    <span class="badge @(a.PurchaseType == "Consignment Bill" ? "badge-cons" : "badge-sale")">
                                        @(a.PurchaseType == "Consignment Bill" ? "Cons." : "Sale")
                                    </span>
                                </td>
                                <td>@a.PurchaseDate.ToString("MM/dd/yyyy")</td>
                                <td class="text-right mono">@a.LiveWeight.ToString("N1")</td>
                                <td class="text-right mono">$@a.LiveRate.ToString("N4")</td>
                                <td class="mono sticky-col sticky-col-5">@(a.AnimalControlNumber ?? "—")</td>
                                <td class="mono">@(a.Tag3 ?? "—")</td>
                                <td>@(a.State ?? "—")</td>
                                <td>@(a.BuyerName ?? "—")</td>
                                <td>@(a.AnimalType2 ?? "—")</td>
                                <td>@(a.VetName ?? "—")</td>
                                <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@a.OfficeUse2">@(a.OfficeUse2 ?? "—")</td>
                                <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@a.Comment">@(a.Comment ?? "—")</td>
                                <!-- Editable kill fields -->
                                <td style="background-color: #f0fdf4">
                                    <input type="text"
                                             name="animalCtrlNo_@a.ControlNo"
                                             value="@a.AnimalControlNumber"
                                            placeholder="Animal Ctrl No"
                                            oninput="markEdited(@a.ControlNo)"
                                            style="width:120px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>
                                <!-- State field -->
                                <td style="background:#f0fdf4">
                                    <input type="hidden" name="origState_@a.ControlNo" value="@(a.State ?? "")" />
                                    <input type="text" name="state_@a.ControlNo"
                                            value="@(a.State ?? "")"
                                            placeholder="State"
                                            oninput="markEdited(@a.ControlNo)"
                                            style="width:90px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>
                                <!-- Vet Name field -->
                                <td style="background:#f0fdf4">
                                    <input type="hidden" name="origVetName_@a.ControlNo" value="@(a.VetName ?? "")" />

                                    <input type="text" name="vetName_@a.ControlNo"
                                            value="@(a.VetName ?? "")"
                                            placeholder="Vet Name"
                                            oninput="markEdited(@a.ControlNo)"
                                            style="width:130px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>
                                <!-- Office Use 2 field -->
                                <td style="background:#f0fdf4">
                                    <input type="hidden" name="origOfficeUse2_@a.ControlNo" value="@(a.OfficeUse2 ?? "")" />

                                    <input type="text" name="officeUse2_@a.ControlNo"
                                            value="@(a.OfficeUse2 ?? "")"
                                            placeholder="Office Use 2"
                                            oninput="markEdited(@a.ControlNo)"
                                            style="width:140px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>

                                <!-- Comment field -->
                                <td style="background:#f0fdf4">
                                    <input type="hidden" name="origComment_@a.ControlNo" value="@(a.Comment ?? "")" />


                                    <input type="text" name="comment_@a.ControlNo"
                                            value="@(a.Comment ?? "")"
                                            placeholder="Comments"
                                            oninput="markEdited(@a.ControlNo)"
                                            style="width:190px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>
                                <td class="sticky-col sticky-col-6" style="background: #f0fdf4;">
                                    <input type="number" 
                                             name="liveWeight_@a.ControlNo"
                                             value="@a.LiveWeight.ToString("0.0")"
                                                step="0.1" min="0"
                                                oninput="markEdited(@a.ControlNo)"
                                                style="width:105px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>
                                <td style="background:#f0fdf4">
                                            <input type="date"
                                                name="killDate_@a.ControlNo"
                                                value=""
                                                onchange="markEdited(@a.ControlNo)"
                                                style="width:114px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>

                                <td style="background:#f0fdf4">
                                    <input type="number" name="hotWeight_@a.ControlNo"
                                            value="@(a.HotWeight?.ToString("0.0") ?? "")"
                                            step="0.1" min="0" placeholder="lbs"
                                            oninput="markEdited(@a.ControlNo)"
                                            style="width:82px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                     
                                </td>
                                <td style="background:#f0fdf4">
                                    <select name="grade_@a.ControlNo"
                                            onchange="markEdited(@a.ControlNo)"
                                            style="width:72px;padding:3px 4px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff">
                                        @foreach (var g in grades)
                                        {
                                            <option value="@g" selected="@(string.Equals(g, a.Grade, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                                    @(string.IsNullOrEmpty(g) ? "—" : g)
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td style="background:#f0fdf4">
                                    <input type="number" name="healthScore_@a.ControlNo"
                                        value="@(a.HealthScore?.ToString() ?? "")"
                                        min="1" max="5" placeholder="1-5"
                                        oninput="markEdited(@a.ControlNo)"
                                        style="width:58px;padding:3px 5px;font-size:12px;border:1px solid var(--gray3);border-radius:4px;background:#fff" />
                                </td>
                                <td style="background:#fef2f2;text-align:center">
                                    <input type="hidden" name="condemned_@a.ControlNo" value="false" />
                                    <input type="checkbox" name="condemned_@a.ControlNo"
                                           value="true"
                                           @(a.IsCondemned ? "checked" : null)
                                           onchange="markEdited(@a.ControlNo)"
                                           style="width:16px;height:16px;cursor:pointer"
                                           title="Mark as condemned" />
                                </td>
                                
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="form-actions" style="margin-top:12px">
            <button type = "submit" formaction="@Url.Action("SaveMarkKilledEdits","Import")" class="btn btn-secondary">Save edits</button>
            <button type="submit" class="btn btn-primary">Mark selected as killed</button>
            <a asp-controller="Animal" asp-action="Index" asp-route-status="pending" class="btn btn-secondary">View animal list</a>
            <span class="form-actions-note" id="footerCount">0 selected</span>
        </div>
    }
</form>

@section Scripts {
<style>
    .badge-sale { background:#dbeafe; color:#1e40af; }
    .badge-cons { background:#fef3c7; color:#92400e; }
    tr.selected-row td { background: #eff6ff !important; }
    tr.selected-row td.sticky-col { background: #eff6ff !important; }
    tr.edited-row td { background: #fffbeb !important; }
    tr.edited-row td.sticky-col { background: #fffbeb !important; }
</style>
<script>

//  Dual scrollbar sync 
(function() {
    var top  = document.getElementById('scrollTop');
    var main = document.getElementById('scrollMain');
    var tbl  = document.getElementById('mainTable');
    if (!top || !main || !tbl) return;

    // Set top mirror width to match table
    document.getElementById('scrollTopInner').style.width = tbl.offsetWidth + 'px';

    var syncing = false;
    top.addEventListener('scroll', function() {
        if (syncing) return; syncing = true;
        main.scrollLeft = top.scrollLeft;
        syncing = false;
    });
    main.addEventListener('scroll', function() {
        if (syncing) return; syncing = true;
        top.scrollLeft = main.scrollLeft;
        syncing = false;
    });
})();

//  Row selection 
function selectAll(val) {
    document.querySelectorAll('.animal-chk').forEach(function(c) {
        c.checked = val;
        highlightRow(c);
    });
    var chk = document.getElementById('selectAllChk');
    if (chk) chk.checked = val;
    updateCount();
}
function highlightRow(chk) {
    var row = chk.closest('tr');
    if (!row) return;
    if (chk.checked) row.classList.add('selected-row');
    else row.classList.remove('selected-row');
}
function updateCount() {
    var n = document.querySelectorAll('.animal-chk:checked').length;
    var txt = n + ' animal' + (n !== 1 ? 's' : '') + ' selected';
    var el1 = document.getElementById('selectedCount');
    var el2 = document.getElementById('footerCount');
    if (el1) el1.textContent = txt;
    if (el2) el2.textContent = txt;
}
function markEdited(id){
    var row = document.getElementById('row-'+id);
    if (!row) return;
    row.classList.add('edited-row');
    
}

document.addEventListener("DOMContentLoaded", function () {
    if (!window.BarnNav) return;
    var table = document.getElementById("mainTable");
    if (!table) return;

    BarnNav.registerGrid({
        container: table,
        rowSelector: "tbody tr.animal-row",
        cellSelector: [
            "input[name^='animalCtrlNo_']",
            "input[name^='liveWeight_']",
            "input[name^='killDate_']",
            "input[name^='hotWeight_']",
            "select[name^='grade_']",
            "input[name^='healthScore_']",
            "input[type='checkbox'][name^='condemned_']"
        ].join(","),
        wrap: true,
        onRowFocus: function (rowEl) {
            if (!rowEl) return;
            var chk = rowEl.querySelector(".animal-chk");
            if (chk && !chk.checked) {
                chk.checked = true;
                if (typeof highlightRow === "function") highlightRow(chk);
                if (typeof updateCount === "function") updateCount();
            }
        }
    });
});

</script>
}
