<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Barn Data System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="app-shell">

    <!--  SIDEBAR TOGGLE  -->
    <button class="sidebar-toggle" id="sidebarToggle" title="Toggle menu" onclick="toggleSidebar()">&#9776;</button>

    <!--  SIDEBAR -->
    <nav class="sidebar">
        <div class="sidebar-brand">
            <!--<div class="brand-tag">trax-it</div> -->
            <!--<div class="brand-name">Slaughter</div> -->
            <div class="brand-name">Barn Data System</div>
        </div>

        <div class="nav-section">Import &amp; intake</div>
        <a asp-controller="Import" asp-action="SaleBill"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" && ViewContext.RouteData.Values["action"]?.ToString() == "SaleBill" ? "active" : "")">
            <span class="nav-dot"></span> Import sale / cons. bill
        </a>
        <a asp-controller="Import" asp-action="Excel"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" && ViewContext.RouteData.Values["action"]?.ToString() is "Excel" or "ExcelPreview" or "ExcelConfirm" ? "active" : "")">
            <span class="nav-dot"></span> Import Excel
        </a>
        <a asp-controller="Import" asp-action="MarkKilled"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" && ViewContext.RouteData.Values["action"]?.ToString() == "MarkKilled" ? "active" : "")">
            <span class="nav-dot"></span> Mark as killed
        </a>

        <div class="nav-section">Manual entry</div>
        <a asp-controller="Animal" asp-action="Index" asp-route-status="pending"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Animal" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <span class="nav-dot"></span> Animal list (pending)
        </a>
        <a asp-controller="Animal" asp-action="Create"
           class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")">
            <span class="nav-dot"></span> New animal record
        </a>
        <a asp-controller="Animal" asp-action="ExportPage"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Animal" && ViewContext.RouteData.Values["action"]?.ToString() is "ExportPage" or "Export" ? "active" : "")">
            <span class="nav-dot"></span> Export Excel
        </a>

        <div class="nav-section">Reports</div>
        <a asp-controller="Report" asp-action="Tally"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Tally" ? "active" : "")">
            <span class="nav-dot"></span> Nightly tally
        </a>
        <a asp-controller="Report" asp-action="FilterView"
           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "FilterView" ? "active" : "")">
            <span class="nav-dot"></span> Filter view
        </a>

        <div class="sidebar-footer">
            <div class="user-chip">
                <div class="user-avatar">BD</div>
                <div class="user-info">
                    <div class="user-name">Barn office</div>
                    <div class="user-role">Data entry</div>
                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN  -->
    <div class="main-area">

        <!-- Top bar -->
        <div class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-path">@ViewData["Subtitle"]</div>
            </div>
            <div class="topbar-right">
                <span class="topbar-date">@DateTime.Today.ToString("dddd, MMMM d, yyyy")</span>
            </div>
        </div>

        <!-- Flash messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="flash flash-success">
                <span class="flash-icon">&#10003;</span>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="flash flash-error">
                <span class="flash-icon">&#33;</span>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Page content -->
        <div class="page-content">
            @RenderBody()
        </div>

    </div>
</div>

<script src="~/js/site.js" asp-append-version="true"></script>
<script>
function toggleSidebar() {
    var sidebar = document.querySelector('.sidebar');
    var btn     = document.getElementById('sidebarToggle');
    var collapsed = sidebar.classList.toggle('collapsed');
    btn.style.left = collapsed ? '14px' : '228px';
    localStorage.setItem('sidebarCollapsed', collapsed ? '1' : '0');
}

(function () {
    "use strict";

    function isVisible(el) {
        return !!(el && (el.offsetWidth || el.offsetHeight || el.getClientRects().length));
    }

    function isEnabled(el) {
        return !!(el && !el.disabled && el.type !== "hidden" && isVisible(el));
    }

    function sortByLeft(a, b) {
        return a.getBoundingClientRect().left - b.getBoundingClientRect().left;
    }

    function clearActive(container, rowClass, cellClass) {
        if (!container) return;
        container.querySelectorAll("." + rowClass).forEach(function (r) { r.classList.remove(rowClass); });
        container.querySelectorAll("." + cellClass).forEach(function (c) { c.classList.remove(cellClass); });
    }

    function findPosition(rows, target) {
        for (var r = 0; r < rows.length; r++) {
            for (var c = 0; c < rows[r].length; c++) {
                var cell = rows[r][c];
                if (cell === target || cell.contains(target) || target.contains(cell)) {
                    return { row: r, col: c };
                }
            }
        }
        return null;
    }

    function getNextPos(rows, pos, key, wrap) {
        var row = pos.row;
        var col = pos.col;
        var rowCount = rows.length;

        function rowLen(i) { return rows[i] ? rows[i].length : 0; }

        if (key === "ArrowRight") {
            col += 1;
            if (col >= rowLen(row)) {
                if (!wrap) col = rowLen(row) - 1;
                else {
                    row = (row + 1) % rowCount;
                    col = 0;
                }
            }
        } else if (key === "ArrowLeft") {
            col -= 1;
            if (col < 0) {
                if (!wrap) col = 0;
                else {
                    row = (row - 1 + rowCount) % rowCount;
                    col = Math.max(0, rowLen(row) - 1);
                }
            }
        } else if (key === "ArrowDown") {
            row = wrap ? (row + 1) % rowCount : Math.min(row + 1, rowCount - 1);
            col = Math.min(col, Math.max(0, rowLen(row) - 1));
        } else if (key === "ArrowUp") {
            row = wrap ? (row - 1 + rowCount) % rowCount : Math.max(row - 1, 0);
            col = Math.min(col, Math.max(0, rowLen(row) - 1));
        }

        return { row: row, col: col };
    }

    function applyActive(container, rows, pos, rowClass, cellClass, onRowFocus) {
        clearActive(container, rowClass, cellClass);
        var rowEl = rows[pos.row][0] ? rows[pos.row][0].closest("tr") : null;
        var cellEl = rows[pos.row][pos.col];

        if (rowEl) rowEl.classList.add(rowClass);
        if (cellEl) cellEl.classList.add(cellClass);

        if (typeof onRowFocus === "function") onRowFocus(rowEl, pos.row);

        if (cellEl && typeof cellEl.focus === "function") {
            cellEl.focus({ preventScroll: true });
            if (typeof cellEl.scrollIntoView === "function") {
                cellEl.scrollIntoView({ block: "nearest", inline: "nearest" });
            }
        }
    }

    function registerCustomGrid(options) {
        var container = options.container;
        if (!container) return;

        var rowClass = options.rowClass || "kbd-row-active";
        var cellClass = options.cellClass || "kbd-cell-active";
        var wrap = options.wrap !== false;

        container.addEventListener("keydown", function (e) {
            if (!e || !e.key) return;
            if (["ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown"].indexOf(e.key) < 0) return;

            var rows = (options.getRows ? options.getRows() : []) || [];
            rows = rows
                .map(function (r) { return (r || []).filter(isEnabled).sort(sortByLeft); })
                .filter(function (r) { return r.length > 0; });

            if (!rows.length) return;

            var pos = findPosition(rows, e.target);
            if (!pos) return;

            e.preventDefault();
            var next = getNextPos(rows, pos, e.key, wrap);
            applyActive(container, rows, next, rowClass, cellClass, options.onRowFocus);
        });

        container.addEventListener("focusin", function (e) {
            var rows = (options.getRows ? options.getRows() : []) || [];
            rows = rows
                .map(function (r) { return (r || []).filter(isEnabled).sort(sortByLeft); })
                .filter(function (r) { return r.length > 0; });

            if (!rows.length) return;
            var pos = findPosition(rows, e.target);
            if (!pos) return;
            applyActive(container, rows, pos, rowClass, cellClass, options.onRowFocus);
        });
    }

    function registerGrid(options) {
        var container = options.container;
        if (!container) return;

        registerCustomGrid({
            container: container,
            wrap: options.wrap,
            rowClass: options.rowClass,
            cellClass: options.cellClass,
            onRowFocus: options.onRowFocus,
            getRows: function () {
                var rowNodes = Array.from(container.querySelectorAll(options.rowSelector || "tbody tr"));
                return rowNodes.map(function (row) {
                    return Array.from(row.querySelectorAll(options.cellSelector || "input,select,textarea,button,a"));
                });
            }
        });
    }

    window.BarnNav = {
        registerGrid: registerGrid,
        registerCustomGrid: registerCustomGrid
    };
})();
// Restore state on load
(function() {
    if (localStorage.getItem('sidebarCollapsed') === '1') {
        document.querySelector('.sidebar').classList.add('collapsed');
        var btn = document.getElementById('sidebarToggle');
        if (btn) btn.style.left = '14px';
    }
})();
</script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
