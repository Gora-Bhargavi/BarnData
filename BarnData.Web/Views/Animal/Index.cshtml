@model IEnumerable<BarnData.Data.Entities.Animal>
@{
    var statusFilter = ViewBag.StatusFilter as string ?? "pending";
    var killDateStr  = ViewBag.KillDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var searchTerm  = ViewBag.SearchTerm as string ?? "";
    ViewData["Title"] = statusFilter == "pending" ? "Pending animals"
                      : statusFilter == "killed"  ? "Killed animals — " + killDateStr
                      : "All animals";
    ViewData["Subtitle"] = statusFilter == "pending"
        ? "Animals imported but not yet killed — go to Mark as killed to set kill date"
        : statusFilter == "killed" ? "Animals killed on " + killDateStr
        : "All animal records";
}

<!-- Status tabs -->
<div style="display:flex;gap:0;margin-bottom:16px;border-bottom:2px solid var(--gray3)">
    <a asp-action="Index" asp-route-status="pending"
       style="padding:8px 18px;font-size:13px;font-weight:500;text-decoration:none;border-bottom:2px solid transparent;margin-bottom:-2px;
              @(statusFilter == "pending" ? "color:var(--blue);border-bottom-color:var(--blue)" : "color:var(--text3)")">
        Pending
    </a>
    <a asp-action="Index" asp-route-status="killed" asp-route-killDate="@killDateStr"
       style="padding:8px 18px;font-size:13px;font-weight:500;text-decoration:none;border-bottom:2px solid transparent;margin-bottom:-2px;
              @(statusFilter == "killed" ? "color:var(--blue);border-bottom-color:var(--blue)" : "color:var(--text3)")">
        Killed
    </a>
    <a asp-action="Index" asp-route-status="all"
       style="padding:8px 18px;font-size:13px;font-weight:500;text-decoration:none;border-bottom:2px solid transparent;margin-bottom:-2px;
              @(statusFilter == "all" ? "color:var(--blue);border-bottom-color:var(--blue)" : "color:var(--text3)")">
        All records
    </a>
</div>

<!-- Filter bar with search + multi-vendor -->
<div class="filter-bar">
    <form method="get" asp-action="Index" class="filter-form" id="animal-filter-form">
        <input type="hidden" name="status" value="@statusFilter" />
        @if (statusFilter == "killed")
        {
            <div class="filter-field">
                <label>Kill date</label>
                <input type="date" name="killDate" value="@killDateStr" class="form-control-sm" />
            </div>
        }
        @* Phase 2d — redesigned multi-vendor picker *@
        <div class="filter-field" style="min-width:260px">
            @await Html.PartialAsync("_VendorPicker", new BarnData.Web.Models.VendorPickerModel {
                Id          = "animal",
                HiddenName  = "vendorIds",
                Vendors     = (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.VendorList,
                SelectedIds = ViewBag.VendorIds as string,
                TotalCount  = ViewBag.TotalCount is int tc ? tc : 0,
                Label       = "Filter by vendor"
            })
        </div>
        <button type="submit" class="btn btn-primary btn-sm" id="animal-filter-btn">Filter</button>
    </form>

    <div class="filter-actions">
        <!-- Search box -->
        <div style="display:flex;align-items:center;gap:0;background:#fff;border:1.5px solid var(--gray3);border-radius:6px;padding:0 10px;height:30px;width:280px">
            <span style="color:var(--text3);margin-right:6px;font-size:14px">⌕</span>
            <input type="text"
                id="animal-search"
                name="searchTerm"
                value="@searchTerm"
                form="animal-filter-form"
                placeholder="Search tag or control no…"
                style="border:none;outline:none;font-size:12.5px;width:100%;background:transparent;color:var(--text)">
        </div>
        <a asp-action="Create" class="btn btn-primary">+ New animal record</a>
        @if (statusFilter == "pending")
        {
            <a asp-controller="Import" asp-action="MarkKilled" class="btn btn-secondary">Mark as killed →</a>
        }
        @if (statusFilter == "killed")
        {
            <a asp-controller="Report" asp-action="Tally" asp-route-killDate="@killDateStr" class="btn btn-secondary">
                View tally report
            </a>
        }
    </div>
</div>


<!-- Summary strip -->
<div class="summary-strip" style="margin-bottom:16px">
    <div class="summary-stat">
        <div class="summary-val" id="summary-count">@ViewBag.TotalCount</div>
        <div class="summary-lbl">Animals</div>
    </div>
   
        
    <div class="summary-stat">
        <div class="summary-val" id="summary-livewt">@(((decimal)ViewBag.TotalLiveWeight).ToString("N1"))</div>
        <div class="summary-lbl">Total live wt (lbs)</div>
    </div>
    <div class="summary-divider"></div>
    <div class="summary-stat">
        <div class="summary-val" id="summary-cost">@(((decimal)ViewBag.TotalCost).ToString("N1"))</div>
        <div class="summary-lbl">Total cost</div>
    </div>
    @if (statusFilter == "killed")
    {
        <div class="summary-divider"></div>
        <div class="summary-stat">
            <div class="summary-val" id="summary-hotwt">@(((decimal)ViewBag.TotalHotWeight).ToString("N2"))</div>
            <div class="summary-lbl">Total hot wt (lbs)</div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-title">
            @(statusFilter == "pending" ? "No pending animals"
              : statusFilter == "killed" ? "No animals killed on " + killDateStr
              : "No animal records")
        </div>
        <div class="empty-sub">
            @(statusFilter == "pending"
                ? "Import a sale bill to add animals, or add them manually."
                : statusFilter == "killed"
                    ? "No animals were marked as killed on this date."
                    : "No records found.")
        </div>
        <div style="display:flex;gap:8px;justify-content:center;margin-top:12px">
            <a asp-controller="Import" asp-action="SaleBill" class="btn btn-primary">Import sale bill</a>
            <a asp-action="Create" class="btn btn-secondary">Add manually</a>
        </div>
    </div>
}
else
{
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
        <span id="search-count" style="font-size:12px;color:var(--blue);font-weight:500">
        @(string.IsNullOrWhiteSpace(searchTerm) ? "" : $"Search: {searchTerm} · {ViewBag.TotalCount} match(es)")
    </span>
        <a href="#filter" class="btn btn-sm btn-ghost">Edit filters</a>
    </div>
    <div class="table-card">
    <div class="xl-scroll-box">
    <div class="xl-scroll-inner">
        <table class="data-table animal-index-table" data-colfilter-table style="min-width:2300px;font-size:12px;">
            <thead>
                <tr>
                    <th data-colfilter="number" class="sticky-col" style="min-width:70px;left:0">Ctrl No.</th>
                    <th data-colfilter="text" class="sticky-animalctrl" style="min-width:115px">Animal Ctrl No.</th>
                    <th data-colfilter="text" class="sticky-tag1" style="min-width:90px">Tag 1</th>
                    <th data-colfilter="text" class="sticky-tag2" style="min-width:90px">Tag 2</th>
                    <th data-colfilter="text" style="min-width:100px">Animal Type</th>
                    <!--<th data-colfilter="text" style="min-width:90px">Tag 1</th>
                    <th data-colfilter="text" style="min-width:90px">Tag 2</th>-->
                    <th data-colfilter="date" style="min-width:100px">Purchase Date</th>
                    <th data-colfilter="text" style="min-width:100px">Purchase Type</th>
                    <th data-colfilter="text" style="min-width:130px">Vendor</th>
                    <th data-colfilter="number" class="text-right" style="min-width:75px">Live Wt</th>
                    <th data-colfilter="number" class="text-right" style="min-width:75px">Live Rate</th>
                    <th data-colfilter="date" style="min-width:95px">Kill Date</th>
                    <th data-colfilter="number" class="text-right" style="min-width:70px;background:#162236;color:#9ae6b4">Hot Wt</th>
                    <th data-colfilter="text" style="min-width:50px;background:#162236;color:#9ae6b4">Grade</th>
                    <th data-colfilter="number" style="min-width:40px;background:#162236;color:#9ae6b4">HS</th>
                    <th data-colfilter="text" style="min-width:160px">Comments</th>
                    <!--<th data-colfilter="text" style="min-width:115px">Animal Ctrl No.</th>-->
                    <th data-colfilter="text" style="min-width:70px">Tag 3</th>
                    <th data-colfilter="text" style="min-width:120px">Office Use 2</th>
                    <th data-colfilter="text" style="min-width:45px">State</th>
                    <th data-colfilter="text" style="min-width:100px">Buyer</th>
                    <th data-colfilter="text" style="min-width:100px">Animal Type 2</th>
                    <th data-colfilter="text" style="min-width:100px">Vet Name</th>
                    <th data-colfilter="number" class="text-right" style="min-width:70px">Fetal Blood</th>
                    <th style="min-width:130px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr class="@(a.IsCondemned ? "row-condemned" : "")"
                        data-search="@($"{a.ControlNo} {a.AnimalType} {a.TagNumber1} {a.TagNumber2} {a.Tag3} {a.AnimalControlNumber} {a.PurchaseDate:MM/dd/yyyy} {a.PurchaseType} {a.Vendor?.VendorName} {a.LiveWeight:N1} {a.LiveRate:N4} {(a.KillDate.HasValue ? a.KillDate.Value.ToString("MM/dd/yyyy") : "")} {a.HotWeight?.ToString("N1")} {a.Grade} {a.HealthScore} {a.Comment} {a.OfficeUse2} {a.State} {a.BuyerName} {a.AnimalType2} {a.VetName} {a.FetalBlood?.ToString("N2")}".ToLowerInvariant())"
                        data-livewt="@a.LiveWeight"
                        data-hotwt="@(a.HotWeight ?? 0m)"
                        data-cost="@((a.PurchaseType?.Contains("consignment", StringComparison.OrdinalIgnoreCase) ?? false ? (a.HotWeight ?? 0m) * (a.ConsignmentRate ?? 0m) : a.LiveWeight * a.LiveRate).ToString(System.Globalization.CultureInfo.InvariantCulture))">
                        <td class="mono sticky-col" style="left:0">@a.ControlNo</td>
                        <td class="mono sticky-animalctrl">@(a.AnimalControlNumber ?? "—")</td>
                        <td class="mono sticky-tag1">@a.TagNumber1</td> 
                        <td class="mono sticky-tag2">@(a.TagNumber2 ?? "—")</td>
                        <td>@a.AnimalType</td>
                        <!--<td class="mono">@a.TagNumber1</td>
                        <td class="mono">@(a.TagNumber2 ?? "—")</td>-->
                        <td>@a.PurchaseDate.ToString("MM/dd/yyyy")</td>
                        <td>
                            <span class="badge @(a.PurchaseType == "Consignment Bill" ? "badge-cons" : "badge-sale")">
                                @(a.PurchaseType == "Consignment Bill" ? "Cons." : "Sale")
                            </span>
                        </td>
                        <td style="font-weight:500">@(a.Vendor?.VendorName ?? "—")</td>
                        <td class="text-right mono">@a.LiveWeight.ToString("N1")</td>
                        <td class="text-right mono">$@a.LiveRate.ToString("N4")</td>
                        <td>@(a.KillDate.HasValue ? a.KillDate.Value.ToString("MM/dd/yyyy") : "—")</td>
                        <td class="text-right mono" style="@(a.HotWeight.HasValue ? "color:#1e40af;font-weight:500" : "")">@(a.HotWeight?.ToString("N1") ?? "—")</td>
                        <td>@if (a.Grade != null) { <span class="badge badge-grade">@a.Grade</span> } else { <span>—</span> }</td>
                        <td class="text-center" style="@(a.HealthScore.HasValue ? "color:#1e40af;font-weight:500" : "")">@(a.HealthScore?.ToString() ?? "—")</td>
                        <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@a.Comment">@(a.Comment ?? "—")</td>
                        <!--<td class="mono">@(a.AnimalControlNumber ?? "—")</td>-->
                        <td class="mono">@(a.Tag3 ?? "—")</td>
                        <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@a.OfficeUse2">@(a.OfficeUse2 ?? "—")</td>
                        <td>@(a.State ?? "—")</td>
                        <td>@(a.BuyerName ?? "—")</td>
                        <td>@(a.AnimalType2 ?? "—")</td>
                        <td>@(a.VetName ?? "—")</td>
                        <td class="text-right mono">@(a.FetalBlood?.ToString("N2") ?? "—")</td>
                        <td class="actions-cell" style="white-space:nowrap">
                            <a asp-action="Edit" asp-route-id="@a.ControlNo" class="btn btn-sm btn-secondary">Edit</a>
                            <a asp-action="Detail" asp-route-id="@a.ControlNo" class="btn btn-sm btn-ghost">View</a>
                                    
                            @if (a.KillStatus != "Flagged")
                            {
                                <form method="post" asp-action="Delete"
                                      asp-route-id="@a.ControlNo"
                                      asp-route-killDate="@killDateStr"
                                      style="display:inline"
                                      onsubmit="return confirm('Remove animal #@a.ControlNo?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger-ghost">Del</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            @if (statusFilter == "killed")
            {
                <tfoot>
                    <tr class="table-total-row">
                        <td colspan="10" class="text-right total-label">Totals</td>
                        <td class="text-right mono">@Model.Sum(a => a.HotWeight ?? 0).ToString("N1")</td>
                        <td colspan="12"></td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
    </div>
    </div>
}

@* ── Pagination (pending only) ── *@
@{
    var vendorQuery = !string.IsNullOrWhiteSpace(ViewBag.VendorIds as string)
        ? "&vendorIds=" + Uri.EscapeDataString((string)ViewBag.VendorIds)
        : (ViewBag.VendorId != null ? "&vendorId=" + ViewBag.VendorId : "");

    var searchQuery = !string.IsNullOrWhiteSpace(searchTerm)
        ? "&searchTerm=" + Uri.EscapeDataString(searchTerm)
        : "";
}
@if (ViewBag.StatusFilter == "pending" && ViewBag.TotalPages > 1)
{
    <div style="display:flex;align-items:center;gap:8px;padding:12px 0;flex-wrap:wrap">
        <span style="font-size:12.5px;color:var(--text3)">
            Page <strong>@ViewBag.CurrentPage</strong> of <strong>@ViewBag.TotalPages</strong>
            · Showing @((ViewBag.CurrentPage-1)*ViewBag.PageSize+1)–@(Math.Min((int)ViewBag.CurrentPage*(int)ViewBag.PageSize,(int)ViewBag.TotalCount))
            of <strong>@ViewBag.TotalCount</strong> pending records
        </span>
        <div style="display:flex;gap:4px;margin-left:auto">
            @if ((int)ViewBag.CurrentPage > 1)
            {
                <a href="?status=pending&page=1@vendorQuery@searchQuery" class="btn btn-secondary btn-sm">« First</a>
                <a href="?status=pending&page=@((int)ViewBag.CurrentPage-1)@vendorQuery@searchQuery" class="btn btn-secondary btn-sm">‹ Prev</a>
            }
            @for (int p = Math.Max(1,(int)ViewBag.CurrentPage-2); p <= Math.Min((int)ViewBag.TotalPages,(int)ViewBag.CurrentPage+2); p++)
            {
                <a href="?status=pending&page=@p@vendorQuery@searchQuery"
                   class="btn @(p==(int)ViewBag.CurrentPage ? "btn-primary" : "btn-secondary") btn-sm">@p</a>
            }
            @if ((int)ViewBag.CurrentPage < (int)ViewBag.TotalPages)
            {
                <a href="?status=pending&page=@((int)ViewBag.CurrentPage+1)@vendorQuery@searchQuery" class="btn btn-secondary btn-sm">Next ›</a>
                <a href="?status=pending&page=@ViewBag.TotalPages@vendorQuery@searchQuery" class="btn btn-secondary btn-sm">Last »</a>
            }
        </div>
    </div>
}

@section Scripts {
<script src="~/js/column-filter.js" asp-append-version="true"></script>
<script src="~/js/vendor-picker.js" asp-append-version="true"></script>
<style>
    .badge-sale { background:#dbeafe; color:#1e40af; }
    .badge-cons { background:#fef3c7; color:#92400e; }
    .vendor-chip { background:#eff6ff;color:#1e40af;border-radius:20px;padding:1px 7px;font-size:11.5px;display:inline-flex;align-items:center;gap:3px; }
    #vendor-dropdown label:hover { background:var(--gray1); }
    /*.xl-scroll-inner thead .sticky-col { background: #1e2f47 !important; color:#fff !important; z-index: 4 !important; }
    .xl-scroll-inner .sticky-col { background: #fff; }
    .row-condemned .sticky-col { background: #fef2f2 !important; }*/
</style>
<script>
// Search + summary sync
    function getTableRows() {
        return Array.from(document.querySelectorAll('.data-table tbody tr'));
    }

    function isRowVisible(row) {
        return row.style.display !== 'none' && !row.classList.contains('cf-hidden');
    }

    function refreshVisibleSummary() {
        var rows = getTableRows().filter(isRowVisible);

        var count = rows.length;
        var totalLiveWt = rows.reduce(function (sum, row) {
            return sum + (parseFloat(row.dataset.livewt || '0') || 0);
        }, 0);
        var totalHotWt = rows.reduce(function (sum, row) {
            return sum + (parseFloat(row.dataset.hotwt || '0') || 0);
        }, 0);
        var totalCost = rows.reduce(function (sum, row) {
            return sum + (parseFloat(row.dataset.cost || '0') || 0);
        }, 0);

        var countEl = document.getElementById('summary-count');
        var liveWtEl = document.getElementById('summary-livewt');
        var costEl = document.getElementById('summary-cost');
        var hotWtEl = document.getElementById('summary-hotwt');

        if (countEl) countEl.textContent = count.toString();
        if (liveWtEl) liveWtEl.textContent = totalLiveWt.toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
        if (costEl) costEl.textContent = totalCost.toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
        if (hotWtEl) hotWtEl.textContent = totalHotWt.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    /*function searchAnimals() {
            var q = (document.getElementById('animal-search')?.value || '').toLowerCase().trim();
            var rows = getTableRows();

            rows.forEach(function (row) {
            var haystack = ((row.dataset.search || row.textContent || '') + '').toLowerCase();
            var matches = !q || haystack.includes(q);
            // Only show if it matches search AND isn't hidden by column filter
            var isHiddenByFilter = row.classList.contains('cf-hidden');
            row.style.display = (matches && !isHiddenByFilter) ? '' : 'none';
        });

        var visibleRows = rows.filter(isRowVisible);
        var countEl = document.getElementById('search-count');
        if (countEl) {
            countEl.textContent = q ? (visibleRows.length + ' of ' + rows.length + ' shown') : '';
        }

        refreshVisibleSummary();
    }*/

    // Vendor picker
    document.addEventListener('vp:apply', function (e) {
        if (e.detail && e.detail.id === 'animal') {
            document.getElementById('animal-filter-form').submit();
        }
    });

    function initAnimalIndexPage() {
    /*var searchBox = document.getElementById('animal-search');
    if (searchBox && searchBox.dataset.bound !== '1') {
        searchBox.addEventListener('input', searchAnimals);
        searchBox.dataset.bound = '1';
    }*/

    var tbody = document.querySelector('.data-table tbody');
    if (tbody && tbody.dataset.summaryBound !== '1') {
        var observer = new MutationObserver(function () {
            refreshVisibleSummary();
        });

        observer.observe(tbody, {
            subtree: true,
            attributes: true,
            attributeFilter: ['class', 'style']
        });

        tbody.dataset.summaryBound = '1';
    }

    refreshVisibleSummary();

    if (!window.BarnNav) return;
    var table = document.querySelector(".table-card .data-table");
    if (!table) return;
    BarnNav.registerGrid({
        container: table,
        rowSelector: "tbody tr",
        cellSelector: ".actions-cell a, .actions-cell button",
        wrap: true
    });
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimalIndexPage);
} else {
    initAnimalIndexPage();
}
</script>
}
