@model IEnumerable<BarnData.Data.Entities.Animal>
@{
    ViewData["Title"]    = "Animal records";
    ViewData["Subtitle"] = $"Kill date: {ViewBag.KillDate}";
}

<div class="filter-bar">
    <form method="get" asp-action="Index" class="filter-form">
        <div class="filter-field">
            <label>Kill date</label>
            <input type="date" name="killDate" value="@ViewBag.KillDate" class="form-control-sm" />
        </div>
        <div class="filter-field">
            <label>Vendor</label>
            <select name="vendorId" class="form-control-sm">
                <option value="">All vendors</option>
                @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.VendorList)
                {
                    <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Filter</button>
        <a asp-action="Index" class="btn btn-secondary btn-sm">Today</a>
    </form>

    <div class="filter-actions">
        <a asp-action="Create" class="btn btn-primary">+ New animal record</a>
        <a asp-controller="Report" asp-action="Tally"
           asp-route-killDate="@ViewBag.KillDate" class="btn btn-secondary">
            View tally report
        </a>
    </div>
</div>

<!-- Summary strip -->
<div class="summary-strip">
    <div class="summary-stat">
        <div class="summary-val">@ViewBag.TotalCount</div>
        <div class="summary-lbl">Animals</div>
    </div>
    <div class="summary-divider"></div>
    <div class="summary-stat">
        <div class="summary-val">@ViewBag.TotalLiveWeight.ToString("N1")</div>
        <div class="summary-lbl">Total live wt (lbs)</div>
    </div>
    <div class="summary-divider"></div>
    <div class="summary-stat">
        <div class="summary-val">@ViewBag.TotalHotWeight.ToString("N1")</div>
        <div class="summary-lbl">Total hot wt (lbs)</div>
    </div>
    @if ((decimal)ViewBag.TotalLiveWeight > 0)
    {
        <div class="summary-divider"></div>
        <div class="summary-stat">
            <div class="summary-val">
                @(((decimal)ViewBag.TotalHotWeight / (decimal)ViewBag.TotalLiveWeight * 100).ToString("N1"))%
            </div>
            <div class="summary-lbl">Avg yield</div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-title">No records for this date</div>
        <div class="empty-sub">No animal records found for @ViewBag.KillDate</div>
        <a asp-action="Create" class="btn btn-primary" style="margin-top:12px">
            + Add first animal record
        </a>
    </div>
}
else
{
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Control No.</th>
                    <th>Vendor</th>
                    <th>Tag 1</th>
                    <th>Tag 2</th>
                    <th>Type</th>
                    <th>Program</th>
                    <th class="text-right">Live wt</th>
                    <th class="text-right">Hot wt</th>
                    <th>Grade</th>
                    <th>HS</th>
                    <th>Kill date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr class="@(a.KillStatus == "Flagged" ? "row-flagged" : "")">
                        <td class="mono">@a.ControlNo</td>
                        <td>@(a.Vendor?.VendorName ?? "—")</td>
                        <td class="mono">@a.TagNumber1</td>
                        <td class="mono">@(a.TagNumber2 ?? "—")</td>
                        <td>@a.AnimalType</td>
                        <td><span class="badge badge-prog">@a.ProgramCode</span></td>
                        <td class="text-right mono">@a.LiveWeight.ToString("N1")</td>
                        <td class="text-right mono">@(a.HotWeight?.ToString("N1") ?? "—")</td>
                        <td><span class="badge badge-grade">@a.Grade</span></td>
                        <td class="text-center">@a.HealthScore</td>
                        <td>@a.KillDate.ToString("MM/dd/yyyy")</td>
                        <td>
                            <span class="badge badge-status-@a.KillStatus.ToLower()">
                                @a.KillStatus
                            </span>
                        </td>
                        <td class="actions-cell">
                            <a asp-action="Edit" asp-route-id="@a.ControlNo"
                               class="btn btn-sm btn-secondary">Edit</a>
                            <a asp-action="Detail" asp-route-id="@a.ControlNo"
                               class="btn btn-sm btn-ghost">View</a>
                            @if (a.KillStatus != "Flagged")
                            {
                                <form method="post" asp-action="Delete"
                                      asp-route-id="@a.ControlNo"
                                      asp-route-killDate="@ViewBag.KillDate"
                                      style="display:inline"
                                      onsubmit="return confirm('Remove animal #@a.ControlNo from this list?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger-ghost">
                                        Remove
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-total-row">
                    <td colspan="6" class="text-right total-label">Totals</td>
                    <td class="text-right mono">@Model.Sum(a => a.LiveWeight).ToString("N1")</td>
                    <td class="text-right mono">@Model.Sum(a => a.HotWeight ?? 0).ToString("N1")</td>
                    <td colspan="5"></td>
                </tr>
            </tfoot>
        </table>
    </div>
}
