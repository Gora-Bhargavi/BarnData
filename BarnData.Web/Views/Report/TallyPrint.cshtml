@model IEnumerable<BarnData.Data.Entities.Animal>
@{
    Layout = null;
    var date    = ViewBag.KillDate as DateTime? ?? DateTime.Today;
    var animals = Model.ToList();
}
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8"/>
<style>
* { box-sizing:border-box; margin:0; padding:0; }
body { font-family: Arial, sans-serif; font-size: 9px; color: #0f172a; }
h1 { font-size:13px; margin-bottom:2px; }
.sub { font-size:9px; color:#64748b; margin-bottom:8px; }
.stats { display:flex; gap:20px; margin-bottom:10px; }
.stat { }
.stat-val { font-size:14px; font-weight:700; }
.stat-lbl { font-size:8px; color:#64748b; }
table { width:100%; border-collapse:collapse; font-size:8px; }
th { background:#1e2f47; color:#fff; padding:3px 5px; text-align:left; font-weight:600; white-space:nowrap; }
td { padding:2px 5px; border-bottom:0.5px solid #e2e8f0; white-space:nowrap; }
tr:nth-child(even) td { background:#f8fafc; }
.condemned td { background:#fee2e2 !important; }
tfoot td { font-weight:700; background:#e2e8f0 !important; }
.text-right { text-align:right; }
</style>
</head>
<body>
<h1>Animal Records — @date.ToString("MMMM d, yyyy")</h1>
<div class="sub">Generated: @DateTime.Now.ToString("MM/dd/yyyy h:mm tt") &nbsp;|&nbsp; Total: @animals.Count &nbsp;|&nbsp; Condemned: @animals.Count(a => a.IsCondemned) &nbsp;|&nbsp; Passed: @animals.Count(a => !a.IsCondemned)</div>
<div class="stats">
    <div class="stat"><div class="stat-val">@animals.Sum(a => a.LiveWeight).ToString("N0")</div><div class="stat-lbl">Total live wt (lbs)</div></div>
    <div class="stat"><div class="stat-val">@animals.Sum(a => a.HotWeight ?? 0).ToString("N0")</div><div class="stat-lbl">Total hot wt (lbs)</div></div>
    <div class="stat"><div class="stat-val">$@animals.Sum(a => a.SaleCost).ToString("N2")</div><div class="stat-lbl">Total cost</div></div>
</div>
<table>
    <thead>
        <tr>
            <th>Ctrl No.</th><th>Vendor</th><th>Tag 1</th><th>Tag 2</th>
            <th>Animal Type</th><th>Purch. Type</th><th>Purch. Date</th><th>Kill Date</th>
            <th class="text-right">Live Wt</th><th class="text-right">Live Rate</th>
            <th class="text-right">Hot Wt</th><th>Grade</th><th>HS</th>
            <th>Comments</th><th>Animal Ctrl No.</th><th>Tag 3</th>
            <th>State</th><th>Buyer</th><th>Animal Type 2</th><th>Vet Name</th><th>Cond</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in animals)
        {
            <tr class="@(a.IsCondemned ? "condemned" : "")">
                <td>@a.ControlNo</td>
                <td>@(a.Vendor?.VendorName ?? "—")</td>
                <td>@a.TagNumber1</td>
                <td>@(a.TagNumber2 ?? "—")</td>
                <td>@a.AnimalType</td>
                <td>@(a.PurchaseType == "Consignment Bill" ? "Cons." : "Sale")</td>
                <td>@a.PurchaseDate.ToString("MM/dd/yy")</td>
                <td>@(a.KillDate.HasValue ? a.KillDate.Value.ToString("MM/dd/yy") : "—")</td>
                <td class="text-right">@a.LiveWeight.ToString("N1")</td>
                <td class="text-right">$@a.LiveRate.ToString("N4")</td>
                <td class="text-right">@(a.HotWeight?.ToString("N1") ?? "—")</td>
                <td>@(a.Grade ?? "—")</td>
                <td>@(a.HealthScore?.ToString() ?? "—")</td>
                <td>@(a.Comment ?? "—")</td>
                <td>@(a.AnimalControlNumber ?? "—")</td>
                <td>@(a.Tag3 ?? "—")</td>
                <td>@(a.State ?? "—")</td>
                <td>@(a.BuyerName ?? "—")</td>
                <td>@(a.AnimalType2 ?? "—")</td>
                <td>@(a.VetName ?? "—")</td>
                <td>@(a.IsCondemned ? "Yes" : "")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="8">Totals</td>
            <td class="text-right">@animals.Sum(a => a.LiveWeight).ToString("N1")</td>
            <td></td>
            <td class="text-right">@animals.Sum(a => a.HotWeight ?? 0).ToString("N1")</td>
            <td colspan="10"></td>
        </tr>
    </tfoot>
</table>
</body>
</html>
